# ============================================================
#   SVPM Alumni Platform — Environment Configuration
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
SESSION_SECRET=svpm_alumni_super_secret_session_key_2024

# --- MongoDB ---
MONGODB_URI=mongodb://localhost:27017/svpm_alumni
# Production: mongodb+srv://<user>:<password>@cluster.mongodb.net/svpm_alumni

# --- JWT ---
JWT_SECRET=svpm_jwt_secret_key_change_in_production
JWT_EXPIRE=7d

# --- Firebase Admin SDK ---
# Download serviceAccountKey.json from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk...

# --- Firebase Client SDK (Frontend) ---
FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXX
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789
FIREBASE_APP_ID=1:123456789:web:abcdefghijklmnop

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
MEMBERSHIP_AMOUNT=1000
# Amount in INR (Life Membership Fee)

# --- Email (Nodemailer / Gmail SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=svpmalumni@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=SVPM Alumni Association <svpmalumni@gmail.com>

# --- Admin Credentials (Seeded on first run) ---
ADMIN_NAME=SVPM Admin
ADMIN_EMAIL=admin@svpmcoe.edu.in
ADMIN_PASSWORD=Admin@SVPM2024

# --- College Details ---
COLLEGE_NAME=SVPM College of Engineering
COLLEGE_LOCATION=Malegaon Bk, Baramati, Pune - 413115
COLLEGE_PHONE=+91-2112-XXXXXX
COLLEGE_EMAIL=info@svpmcoe.edu.in
COLLEGE_WEBSITE=https://www.svpmcoe.edu.in

# --- File Upload ---
MAX_FILE_SIZE=5242880
# 5MB in bytes
UPLOAD_PATH=public/uploads
