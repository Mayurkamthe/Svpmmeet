<!-- Mobile Top Bar -->
<div class="md:hidden fixed top-0 left-0 right-0 z-50 px-4 py-3 flex items-center justify-between shadow-lg" style="background:#0f1e32">
  <a href="/admin/dashboard" class="flex items-center gap-2">
    <div class="w-8 h-8 rounded-full flex items-center justify-center border" style="background:rgba(245,200,66,0.15);border-color:rgba(245,200,66,0.5)">
      <i class="fa-solid fa-shield-halved text-sm" style="color:#f5c842"></i>
    </div>
    <span class="text-white font-bold text-sm">Admin Panel</span>
  </a>
  <button id="admin-hamburger" onclick="toggleAdminSidebar()" class="text-white p-2 rounded-lg transition" style="background:transparent" aria-label="Open menu">
    <i class="fa-solid fa-bars text-xl"></i>
  </button>
</div>

<!-- Overlay -->
<div id="admin-overlay" class="md:hidden fixed inset-0 z-40 hidden" style="background:rgba(0,0,0,0.6)" onclick="closeAdminSidebar()"></div>

<!-- Admin Sidebar -->
<aside id="admin-sidebar" class="w-64 min-h-screen flex flex-col flex-shrink-0 fixed md:static top-0 left-0 z-50 h-screen transition-transform duration-300 ease-in-out" style="background:#0f1e32;transform:translateX(-100%)">

  <!-- Brand -->
  <div class="p-5 flex items-center justify-between" style="border-bottom:1px solid rgba(255,255,255,0.1)">
    <a href="/admin/dashboard" class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full flex items-center justify-center border" style="background:rgba(245,200,66,0.15);border-color:rgba(245,200,66,0.5)">
        <i class="fa-solid fa-shield-halved" style="color:#f5c842"></i>
      </div>
      <div>
        <div class="text-white font-bold text-sm">Admin Panel</div>
        <div class="text-xs" style="color:#8db0d4">SVPM Alumni</div>
      </div>
    </a>
    <button onclick="closeAdminSidebar()" class="md:hidden text-white p-1 ml-2 rounded" style="opacity:0.6" aria-label="Close menu">
      <i class="fa-solid fa-xmark text-lg"></i>
    </button>
  </div>

  <!-- Admin Info -->
  <div class="px-4 py-3" style="border-bottom:1px solid rgba(255,255,255,0.1)">
    <div class="flex items-center gap-2">
      <div class="w-8 h-8 rounded-full flex items-center justify-center" style="background:rgba(245,200,66,0.15)">
        <i class="fa-solid fa-user-shield text-xs" style="color:#f5c842"></i>
      </div>
      <div>
        <div class="text-white text-xs font-semibold truncate"><%= user ? user.name : 'Admin' %></div>
        <div class="text-xs" style="color:#8db0d4">Administrator</div>
      </div>
    </div>
  </div>

  <!-- Nav -->
  <nav class="flex-1 p-3 space-y-1 overflow-y-auto">
    <% const p = locals.currentPath || ''; %>
    <a href="/admin/dashboard" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p === '/admin/dashboard' ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-gauge w-4 text-center"></i> Dashboard
    </a>

    <div class="pt-2 pb-1">
      <div class="text-xs font-bold uppercase tracking-widest px-3" style="color:#3a70a8">Management</div>
    </div>
    <a href="/admin/alumni" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p.includes('/admin/alumni') ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-users w-4 text-center"></i> Alumni
    </a>
    <a href="/admin/memberships" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p.includes('/admin/memberships') ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-id-card w-4 text-center"></i> Memberships
    </a>
    <a href="/admin/payments" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p.includes('/admin/payments') ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-indian-rupee-sign w-4 text-center"></i> Payments
    </a>

    <div class="pt-2 pb-1">
      <div class="text-xs font-bold uppercase tracking-widest px-3" style="color:#3a70a8">Content</div>
    </div>
    <a href="/admin/events" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p.includes('/admin/events') ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-calendar-days w-4 text-center"></i> Events
    </a>
    <a href="/admin/announcements" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm <%= p.includes('/admin/announcements') ? 'active' : '' %>" style="color:#8db0d4">
      <i class="fa-solid fa-bullhorn w-4 text-center"></i> Announcements
    </a>

    <div class="pt-2 pb-1">
      <div class="text-xs font-bold uppercase tracking-widest px-3" style="color:#3a70a8">Export</div>
    </div>
    <a href="/admin/export/alumni" onclick="closeAdminSidebar()" class="sidebar-link flex items-center gap-3 px-3 py-2.5 rounded-lg transition text-sm" style="color:#8db0d4">
      <i class="fa-solid fa-file-excel w-4 text-center"></i> Export Alumni
    </a>
  </nav>

  <!-- Footer -->
  <div class="p-3 space-y-1" style="border-top:1px solid rgba(255,255,255,0.1)">
    <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-lg transition text-xs" style="color:#5f8dbe">
      <i class="fa-solid fa-arrow-left w-4 text-center"></i> Back to Site
    </a>
    <a href="/auth/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg transition text-xs" style="color:#5f8dbe">
      <i class="fa-solid fa-right-from-bracket w-4 text-center"></i> Logout
    </a>
  </div>
</aside>

<style>
  @media (min-width: 768px) {
    #admin-sidebar { transform: translateX(0) !important; position: static !important; height: 100vh; }
    #admin-overlay { display: none !important; }
  }
  .sidebar-link:hover { background: rgba(255,255,255,0.1); color: #fff !important; }
  .sidebar-link.active { background: rgba(255,255,255,0.15); border-left: 3px solid #f5c842; color: #fff !important; }
</style>

<script>
  function toggleAdminSidebar() {
    const sidebar = document.getElementById('admin-sidebar');
    const overlay = document.getElementById('admin-overlay');
    const isOpen = sidebar.style.transform === 'translateX(0px)' || sidebar.style.transform === 'translateX(0)';
    if (isOpen) {
      closeAdminSidebar();
    } else {
      sidebar.style.transform = 'translateX(0)';
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }
  }
  function closeAdminSidebar() {
    document.getElementById('admin-sidebar').style.transform = 'translateX(-100%)';
    document.getElementById('admin-overlay').classList.add('hidden');
    document.body.style.overflow = '';
  }
  // Close on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeAdminSidebar();
  });
</script>
