<!-- Public Navbar -->
<nav class="bg-navy-800 shadow-lg sticky top-0 z-40">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full gradient-header flex items-center justify-center border-2 border-gold-400">
          <i class="fa-solid fa-graduation-cap text-gold-400 text-lg"></i>
        </div>
        <div class="hidden sm:block">
          <div class="text-white font-display font-bold text-base leading-tight">SVPM Alumni</div>
          <div class="text-navy-300 text-xs">Malegaon Bk, Baramati</div>
        </div>
      </a>

      <!-- Desktop Links -->
      <div class="hidden md:flex items-center gap-6 text-sm font-semibold">
        <a href="/" class="text-navy-200 hover:text-gold-400 transition">Home</a>
        <a href="/events" class="text-navy-200 hover:text-gold-400 transition">Events</a>
        <% if (locals.user) { %>
          <a href="/alumni/directory" class="text-navy-200 hover:text-gold-400 transition">Directory</a>
          <% if (user.role === 'admin') { %>
            <a href="/admin/dashboard" class="text-navy-200 hover:text-gold-400 transition">
              <i class="fa-solid fa-shield-halved mr-1"></i>Admin
            </a>
          <% } else { %>
            <a href="/alumni/dashboard" class="text-navy-200 hover:text-gold-400 transition">Dashboard</a>
          <% } %>
          <!-- User Menu -->
          <div class="relative group">
            <button class="flex items-center gap-2 text-white hover:text-gold-400 transition">
              <div class="w-8 h-8 rounded-full bg-navy-600 flex items-center justify-center overflow-hidden border-2 border-navy-500">
                <% if (user.avatar) { %>
                  <img src="<%= user.avatar %>" alt="" class="w-full h-full object-cover">
                <% } else { %>
                  <i class="fa-solid fa-user text-navy-300 text-xs"></i>
                <% } %>
              </div>
              <span class="text-sm"><%= user.name.split(' ')[0] %></span>
              <i class="fa-solid fa-chevron-down text-xs"></i>
            </button>
            <div class="absolute right-0 mt-2 w-48 bg-white rounded-xl shadow-xl border border-gray-100 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
              <a href="/alumni/profile" class="flex items-center gap-2 px-4 py-3 text-gray-700 hover:bg-gray-50 rounded-t-xl text-sm">
                <i class="fa-solid fa-user w-4"></i> My Profile
              </a>
              <a href="/alumni/membership" class="flex items-center gap-2 px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm">
                <i class="fa-solid fa-id-card w-4"></i> Membership
              </a>
              <a href="/alumni/payments" class="flex items-center gap-2 px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm">
                <i class="fa-solid fa-receipt w-4"></i> Payments
              </a>
              <div class="border-t border-gray-100"></div>
              <a href="/auth/logout" class="flex items-center gap-2 px-4 py-3 text-red-600 hover:bg-red-50 rounded-b-xl text-sm">
                <i class="fa-solid fa-right-from-bracket w-4"></i> Logout
              </a>
            </div>
          </div>
        <% } else { %>
          <a href="/auth/login" class="text-navy-200 hover:text-gold-400 transition">Login</a>
          <a href="/auth/register" class="bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold px-4 py-2 rounded-lg transition">
            Register
          </a>
        <% } %>
      </div>

      <!-- Mobile Menu Toggle -->
      <button id="mobile-menu-btn" class="md:hidden text-white p-2">
        <i class="fa-solid fa-bars text-xl"></i>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-navy-900 border-t border-navy-700 px-4 py-3 space-y-2 text-sm font-semibold">
    <a href="/" class="block text-navy-200 py-2">Home</a>
    <a href="/events" class="block text-navy-200 py-2">Events</a>
    <% if (locals.user) { %>
      <a href="/alumni/directory" class="block text-navy-200 py-2">Directory</a>
      <a href="/alumni/dashboard" class="block text-navy-200 py-2">Dashboard</a>
      <a href="/auth/logout" class="block text-red-400 py-2">Logout</a>
    <% } else { %>
      <a href="/auth/login" class="block text-navy-200 py-2">Login</a>
      <a href="/auth/register" class="block text-gold-400 py-2">Register</a>
    <% } %>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
