<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: {50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},
            gold: {400:'#f5c842',500:'#e8b820',600:'#c8a31a'}
          },
          fontFamily: {
            display: ['"Playfair Display"','Georgia','serif'],
            body: ['"Source Sans 3"','system-ui','sans-serif']
          }
        }
      }
    }
  </script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    body { font-family: 'Source Sans 3', system-ui, sans-serif; }
    .gradient-bg { background: linear-gradient(135deg, #0f1e32 0%, #1e3a5f 50%, #2d6a9f 100%); }
    .tab-btn.active { background: white; color: #1e3a5f; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
  </style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">

    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/10 border border-white/20 mb-4">
        <i class="fa-solid fa-graduation-cap text-3xl text-gold-400"></i>
      </div>
      <h1 class="font-display text-3xl font-bold text-white">SVPM Alumni</h1>
      <p class="text-navy-300 text-sm mt-1">Malegaon Bk, Baramati</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-3xl shadow-2xl overflow-hidden">

      <!-- Header -->
      <div class="gradient-bg px-8 py-5">
        <h2 class="text-white font-display text-xl font-bold">Welcome Back</h2>
        <p class="text-navy-300 text-sm">Sign in to your alumni account</p>
      </div>

      <!-- Login Method Tabs -->
      <div class="px-8 pt-6">
        <div class="bg-gray-100 rounded-xl p-1 flex gap-1 text-sm font-semibold">
          <button onclick="switchTab('password')" id="tab-password" class="tab-btn active flex-1 py-2 rounded-lg transition text-center">
            <i class="fa-solid fa-lock mr-1.5 text-xs"></i>Password
          </button>
          <button onclick="switchTab('google')" id="tab-google" class="tab-btn flex-1 py-2 rounded-lg transition text-center text-gray-500">
            <i class="fa-brands fa-google mr-1.5 text-xs"></i>Google
          </button>
          <button onclick="switchTab('otp')" id="tab-otp" class="tab-btn flex-1 py-2 rounded-lg transition text-center text-gray-500">
            <i class="fa-solid fa-mobile-screen mr-1.5 text-xs"></i>OTP
          </button>
        </div>
      </div>

      <!-- Flash Messages -->
      <% if (locals.error_msg && error_msg.length > 0) { %>
      <div class="mx-8 mt-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
        <i class="fa-solid fa-circle-exclamation flex-shrink-0"></i><span><%= error_msg %></span>
      </div>
      <% } %>
      <% if (locals.success_msg && success_msg.length > 0) { %>
      <div class="mx-8 mt-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm">
        <i class="fa-solid fa-circle-check flex-shrink-0"></i><span><%= success_msg %></span>
      </div>
      <% } %>

      <div class="px-8 py-6">

        <!-- Password Tab -->
        <div id="panel-password">
          <form action="/auth/login" method="POST" class="space-y-4">
            <div>
              <label class="block text-gray-700 font-semibold text-sm mb-1.5">Email Address</label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa-solid fa-envelope text-sm"></i></span>
                <input type="email" name="email" required placeholder="your@email.com"
                  class="w-full pl-10 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition" />
              </div>
            </div>
            <div>
              <label class="block text-gray-700 font-semibold text-sm mb-1.5">Password</label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa-solid fa-lock text-sm"></i></span>
                <input type="password" name="password" id="password-field" required placeholder="••••••••"
                  class="w-full pl-10 pr-11 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 focus:border-transparent transition" />
                <button type="button" onclick="togglePassword()" class="absolute right-3.5 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                  <i class="fa-solid fa-eye text-sm" id="eye-icon"></i>
                </button>
              </div>
            </div>
            <div class="flex justify-end">
              <a href="/auth/forgot-password" class="text-navy-600 hover:text-navy-800 text-xs font-semibold">Forgot password?</a>
            </div>
            <button type="submit" class="w-full bg-navy-700 hover:bg-navy-800 text-white font-bold py-3 rounded-xl transition flex items-center justify-center gap-2">
              <i class="fa-solid fa-right-to-bracket"></i> Sign In
            </button>
          </form>
        </div>

        <!-- Google Tab -->
        <div id="panel-google" class="hidden">
          <div class="text-center py-4">
            <div class="w-16 h-16 rounded-2xl bg-gray-50 border border-gray-200 flex items-center justify-center mx-auto mb-4">
              <i class="fa-brands fa-google text-3xl text-red-500"></i>
            </div>
            <p class="text-gray-600 text-sm mb-6 leading-relaxed">
              Sign in quickly with your Google account. If you're new, we'll automatically create your alumni profile.
            </p>
            <button onclick="signInWithGoogle()" id="google-btn"
              class="w-full flex items-center justify-center gap-3 border-2 border-gray-200 hover:border-gray-300 bg-white hover:bg-gray-50 text-gray-700 font-semibold py-3 rounded-xl transition">
              <svg width="20" height="20" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
              Continue with Google
            </button>
            <div id="google-loading" class="hidden mt-4 text-navy-600 text-sm"><i class="fa-solid fa-spinner fa-spin mr-2"></i>Signing in...</div>
          </div>
        </div>

        <!-- OTP Tab -->
        <div id="panel-otp" class="hidden">
          <div id="otp-step1">
            <p class="text-gray-600 text-sm mb-5 leading-relaxed">
              Enter your mobile number to receive a one-time password via SMS.
            </p>
            <div class="mb-4">
              <label class="block text-gray-700 font-semibold text-sm mb-1.5">Mobile Number</label>
              <div class="relative">
                <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400 text-sm font-semibold">+91</span>
                <input type="tel" id="otp-phone" placeholder="9876543210" maxlength="10"
                  class="w-full pl-12 pr-4 py-3 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500" />
              </div>
            </div>
            <div id="recaptcha-container"></div>
            <button onclick="sendOTP()" class="w-full bg-navy-700 hover:bg-navy-800 text-white font-bold py-3 rounded-xl transition">
              <i class="fa-solid fa-paper-plane mr-2"></i>Send OTP
            </button>
          </div>

          <div id="otp-step2" class="hidden">
            <p class="text-gray-600 text-sm mb-4">Enter the 6-digit OTP sent to your number.</p>
            <div class="mb-4">
              <label class="block text-gray-700 font-semibold text-sm mb-1.5">OTP Code</label>
              <input type="text" id="otp-code" placeholder="123456" maxlength="6"
                class="w-full px-4 py-3 border border-gray-200 rounded-xl text-sm text-center tracking-widest text-2xl font-mono focus:outline-none focus:ring-2 focus:ring-navy-500" />
            </div>
            <button onclick="verifyOTP()" class="w-full bg-navy-700 hover:bg-navy-800 text-white font-bold py-3 rounded-xl transition">
              <i class="fa-solid fa-shield-halved mr-2"></i>Verify OTP
            </button>
            <button onclick="document.getElementById('otp-step1').classList.remove('hidden'); document.getElementById('otp-step2').classList.add('hidden')" class="w-full mt-2 text-navy-600 hover:text-navy-800 text-sm font-semibold py-2">
              Change Number
            </button>
          </div>
        </div>

        <!-- Register Link -->
        <div class="mt-6 pt-5 border-t border-gray-100 text-center text-sm">
          <span class="text-gray-500">New alumni?</span>
          <a href="/auth/register" class="text-navy-700 font-bold hover:text-navy-900 ml-1">Create Account</a>
        </div>

      </div>
    </div>

    <!-- College Info -->
    <div class="text-center mt-6 text-navy-400 text-xs">
      <i class="fa-solid fa-building-columns mr-1"></i>
      SVPM College of Engineering, Malegaon Bk, Baramati, Pune
    </div>

  </div>

  <!-- Firebase SDK -->
  <script type="module">
    import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
    import { getAuth, GoogleAuthProvider, signInWithPopup, RecaptchaVerifier, signInWithPhoneNumber } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-auth.js';

    const firebaseConfig = <%- JSON.stringify(firebaseConfig) %>;
    let app, auth, confirmationResult;

    try {
      app = initializeApp(firebaseConfig);
      auth = getAuth(app);
    } catch(e) {
      console.warn('Firebase not configured:', e.message);
    }

    window.signInWithGoogle = async () => {
      if (!auth) {
        alert('Firebase not configured. Please set up Firebase credentials in .env');
        return;
      }
      const btn = document.getElementById('google-btn');
      const loading = document.getElementById('google-loading');
      btn.classList.add('hidden');
      loading.classList.remove('hidden');

      try {
        const provider = new GoogleAuthProvider();
        const result = await signInWithPopup(auth, provider);
        const idToken = await result.user.getIdToken();

        const res = await fetch('/auth/firebase', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            idToken,
            name: result.user.displayName,
            email: result.user.email,
            photoURL: result.user.photoURL,
            provider: 'google'
          })
        });
        const data = await res.json();
        if (data.success) window.location.href = data.redirect;
        else throw new Error(data.message);
      } catch (err) {
        alert('Google sign-in failed: ' + err.message);
        btn.classList.remove('hidden');
        loading.classList.add('hidden');
      }
    };

    window.sendOTP = async () => {
      if (!auth) { alert('Firebase not configured'); return; }
      const phone = document.getElementById('otp-phone').value.trim();
      if (phone.length !== 10) { alert('Enter a valid 10-digit mobile number'); return; }

      try {
        if (!window.recaptchaVerifier) {
          window.recaptchaVerifier = new RecaptchaVerifier(auth, 'recaptcha-container', { size: 'invisible' });
        }
        confirmationResult = await signInWithPhoneNumber(auth, `+91${phone}`, window.recaptchaVerifier);
        document.getElementById('otp-step1').classList.add('hidden');
        document.getElementById('otp-step2').classList.remove('hidden');
      } catch (err) {
        alert('Failed to send OTP: ' + err.message);
      }
    };

    window.verifyOTP = async () => {
      if (!confirmationResult) { alert('Please request OTP first'); return; }
      const code = document.getElementById('otp-code').value.trim();
      try {
        const result = await confirmationResult.confirm(code);
        const idToken = await result.user.getIdToken();
        const res = await fetch('/auth/firebase', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ idToken, phone: result.user.phoneNumber, provider: 'phone' })
        });
        const data = await res.json();
        if (data.success) window.location.href = data.redirect;
        else throw new Error(data.message);
      } catch (err) {
        alert('OTP verification failed: ' + err.message);
      }
    };
  </script>

  <script>
    function switchTab(tab) {
      ['password', 'google', 'otp'].forEach(t => {
        document.getElementById(`panel-${t}`).classList.add('hidden');
        const btn = document.getElementById(`tab-${t}`);
        btn.classList.remove('active');
        btn.classList.add('text-gray-500');
      });
      document.getElementById(`panel-${tab}`).classList.remove('hidden');
      const active = document.getElementById(`tab-${tab}`);
      active.classList.add('active');
      active.classList.remove('text-gray-500');
    }

    function togglePassword() {
      const f = document.getElementById('password-field');
      const icon = document.getElementById('eye-icon');
      if (f.type === 'password') { f.type = 'text'; icon.classList.replace('fa-eye', 'fa-eye-slash'); }
      else { f.type = 'password'; icon.classList.replace('fa-eye-slash', 'fa-eye'); }
    }
  </script>
</body>
</html>
