<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><title>Error</title><script src="https://cdn.tailwindcss.com"></script><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/><style>body{font-family:system-ui,sans-serif;background:linear-gradient(135deg,#0f1e32,#1e3a5f);}</style></head>
<body class="min-h-screen flex items-center justify-center px-4 text-center">
  <div class="max-w-md">
    <i class="fa-solid fa-circle-exclamation text-5xl text-red-400 mb-5 block"></i>
    <h1 class="text-3xl font-bold text-white mb-3">Something Went Wrong</h1>
    <% if(locals.message){%><p class="text-blue-200 mb-6 font-mono text-sm bg-black/20 p-3 rounded-xl"><%=message%></p><%}%>
    <a href="/" class="inline-block bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-bold px-6 py-3 rounded-xl transition"><i class="fa-solid fa-home mr-2"></i>Go Home</a>
  </div>
</body>
</html>
