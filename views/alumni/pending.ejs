<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-bg{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}</style>
</head>
<body class="gradient-bg min-h-screen flex items-center justify-center px-4">
  <div class="text-center max-w-md">
    <div class="w-24 h-24 rounded-3xl bg-white/10 border border-white/20 flex items-center justify-center mx-auto mb-6">
      <i class="fa-solid fa-hourglass-half text-5xl text-amber-400"></i>
    </div>
    <h1 class="font-display text-3xl font-bold text-white mb-3">Account Under Review</h1>
    <p class="text-navy-200 text-lg mb-2">Welcome, <strong class="text-white"><%= user ? user.name : 'Alumni' %></strong>!</p>
    <p class="text-navy-300 leading-relaxed mb-8">
      Your alumni registration is being reviewed by our admin team. You'll receive an email once your account is approved — usually within 1–2 business days.
    </p>
    <div class="bg-white/10 border border-white/20 rounded-2xl p-5 mb-8 text-left space-y-3">
      <div class="flex items-center gap-3 text-white">
        <i class="fa-solid fa-circle-check text-emerald-400 w-5"></i>
        <span class="text-sm">Registration complete</span>
      </div>
      <div class="flex items-center gap-3 text-white">
        <i class="fa-solid fa-hourglass-half text-amber-400 w-5"></i>
        <span class="text-sm">Admin review in progress</span>
      </div>
      <div class="flex items-center gap-3 text-navy-400">
        <i class="fa-solid fa-circle text-navy-600 w-5 text-xs"></i>
        <span class="text-sm">Account activated</span>
      </div>
    </div>
    <div class="flex gap-3 justify-center">
      <a href="/alumni/profile" class="bg-white/10 hover:bg-white/20 border border-white/20 text-white font-semibold px-5 py-2.5 rounded-xl text-sm transition">
        <i class="fa-solid fa-user mr-2"></i>View Profile
      </a>
      <a href="/auth/logout" class="bg-red-500/20 hover:bg-red-500/30 border border-red-400/30 text-red-300 font-semibold px-5 py-2.5 rounded-xl text-sm transition">
        <i class="fa-solid fa-right-from-bracket mr-2"></i>Logout
      </a>
    </div>
  </div>
</body>
</html>
