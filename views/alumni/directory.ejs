<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{400:'#f5c842',500:'#e8b820',600:'#c8a31a'}},fontFamily:{display:['"Playfair Display"','Georgia','serif']}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}.badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}.card-hover{transition:transform 0.2s,box-shadow 0.2s;}.card-hover:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,0,0,0.1);}</style>
</head>
<body class="bg-gray-50">
<div class="flex min-h-screen md:min-h-screen">
  <% locals.currentPath = '/alumni/directory'; %>
  <%- include('../partials/alumni-sidebar') %>

  <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4">
      <h1 class="text-xl font-bold text-navy-800">Alumni Directory</h1>
      <p class="text-gray-500 text-sm">Browse and connect with SVPM alumni — <%= total %> members found</p>
    </div>

    <div class="p-4 sm:p-6">
      <!-- Search & Filters -->
      <form method="GET" action="/alumni/directory" class="bg-white rounded-2xl border border-gray-100 p-5 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
          <div class="lg:col-span-2 relative">
            <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa-solid fa-magnifying-glass text-xs"></i></span>
            <input type="text" name="name" value="<%= query.name || '' %>" placeholder="Search by name or company..."
              class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500"/>
          </div>
          <div>
            <select name="branch" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 bg-white">
              <option value="">All Branches</option>
              <% branches.forEach(b => { %><option value="<%= b %>" <%= query.branch === b ? 'selected' : '' %>><%= b %></option><% }) %>
            </select>
          </div>
          <div>
            <select name="year" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-navy-500 bg-white">
              <option value="">All Years</option>
              <% years.forEach(y => { %><option value="<%= y %>" <%= query.year == y ? 'selected' : '' %>><%= y %></option><% }) %>
            </select>
          </div>
          <div class="flex gap-2">
            <button type="submit" class="flex-1 bg-navy-700 hover:bg-navy-800 text-white font-semibold py-2.5 rounded-xl text-sm transition">
              <i class="fa-solid fa-search mr-1"></i>Search
            </button>
            <a href="/alumni/directory" class="px-3 py-2.5 border border-gray-200 rounded-xl text-gray-500 hover:bg-gray-50 transition text-sm">
              <i class="fa-solid fa-xmark"></i>
            </a>
          </div>
        </div>
      </form>

      <!-- Alumni Grid -->
      <% if (alumni && alumni.length > 0) { %>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4 mb-6">
        <% alumni.forEach(a => { %>
        <div class="bg-white rounded-2xl border border-gray-100 p-5 card-hover text-center">
          <div class="w-16 h-16 rounded-2xl mx-auto mb-3 flex items-center justify-center overflow-hidden bg-navy-50 border-2 border-navy-100">
            <% if (a.avatar) { %>
              <img src="<%= a.avatar %>" alt="" class="w-full h-full object-cover">
            <% } else { %>
              <span class="text-navy-600 font-display font-bold text-2xl"><%= a.name.charAt(0) %></span>
            <% } %>
          </div>
          <h4 class="font-bold text-navy-800 text-base mb-0.5"><%= a.name %></h4>
          <% if (a.profile?.designation) { %>
          <p class="text-gray-500 text-xs mb-1"><%= a.profile.designation %><% if (a.profile.company) { %> @ <%= a.profile.company %><% } %></p>
          <% } %>
          <div class="flex items-center justify-center gap-1 mb-3">
            <span class="text-xs bg-navy-100 text-navy-600 px-2 py-0.5 rounded-full font-semibold"><%= a.profile?.passOutYear || 'N/A' %></span>
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded-full truncate max-w-24" title="<%= a.profile?.branch %>"><%= a.profile?.branch?.split(' ')[0] || 'N/A' %></span>
            <% if (a.membershipStatus === 'approved') { %>
            <span class="text-xs px-2 py-0.5 rounded-full font-bold badge-life"><i class="fa-solid fa-star text-xs"></i></span>
            <% } %>
          </div>
          <div class="flex items-center justify-center gap-2 flex-wrap">
            <% if (a.profile?.location) { %>
            <span class="text-xs text-gray-400 flex items-center gap-1"><i class="fa-solid fa-location-dot text-gray-300"></i><%= a.profile.location %></span>
            <% } %>
          </div>
          <div class="mt-3 pt-3 border-t border-gray-50 flex gap-2">
            <a href="mailto:<%= a.email %>" class="flex-1 text-center text-xs font-semibold text-navy-600 hover:text-navy-800 py-1.5 rounded-lg bg-navy-50 hover:bg-navy-100 transition">
              <i class="fa-solid fa-envelope mr-1"></i>Contact
            </a>
            <% if (a.profile?.linkedin) { %>
            <a href="<%= a.profile.linkedin %>" target="_blank" class="px-3 text-center text-xs font-semibold text-blue-600 py-1.5 rounded-lg bg-blue-50 hover:bg-blue-100 transition">
              <i class="fa-brands fa-linkedin"></i>
            </a>
            <% } %>
          </div>
        </div>
        <% }) %>
      </div>

      <!-- Pagination -->
      <% if (totalPages > 1) { %>
      <div class="flex items-center justify-center gap-2">
        <% if (page > 1) { %>
        <a href="?page=<%= page-1 %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k,v]) => `${k}=${v}`).join('&') %>"
          class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">
          <i class="fa-solid fa-chevron-left mr-1"></i>Prev
        </a>
        <% } %>
        <% for (let i = Math.max(1, page-2); i <= Math.min(totalPages, page+2); i++) { %>
        <a href="?page=<%= i %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k,v]) => `${k}=${v}`).join('&') %>"
          class="px-4 py-2 rounded-xl text-sm font-semibold transition <%= i === page ? 'bg-navy-700 text-white' : 'border border-gray-200 text-gray-600 hover:bg-gray-50' %>">
          <%= i %>
        </a>
        <% } %>
        <% if (page < totalPages) { %>
        <a href="?page=<%= page+1 %>&<%= Object.entries(query).filter(([k]) => k !== 'page').map(([k,v]) => `${k}=${v}`).join('&') %>"
          class="px-4 py-2 border border-gray-200 rounded-xl text-sm font-semibold text-gray-600 hover:bg-gray-50 transition">
          Next <i class="fa-solid fa-chevron-right ml-1"></i>
        </a>
        <% } %>
      </div>
      <% } %>

      <% } else { %>
      <div class="text-center py-16 bg-white rounded-2xl border border-gray-100">
        <i class="fa-solid fa-users text-5xl text-gray-200 mb-4"></i>
        <h3 class="text-gray-500 font-semibold">No alumni found</h3>
        <p class="text-gray-400 text-sm mt-1">Try adjusting your filters</p>
        <a href="/alumni/directory" class="inline-block mt-4 text-navy-600 hover:text-navy-800 font-semibold text-sm">Clear Filters</a>
      </div>
      <% } %>
    </div>
  </main>
</div>
</body>
</html>
