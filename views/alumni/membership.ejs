<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{400:'#f5c842',500:'#e8b820',600:'#c8a31a'}}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
  <style>
    body{font-family:'Source Sans 3',system-ui,sans-serif;}
    .gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}
    .sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}
    .sidebar-link:hover{background:rgba(255,255,255,0.1);}
    .badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}
    .plan-card{transition:border-color .15s,box-shadow .15s;}
    .plan-card.selected{border-color:#1e3a5f;box-shadow:0 0 0 3px rgba(30,58,95,.15);}
  </style>
</head>
<body class="bg-gray-50">
<div class="flex min-h-screen">
  <% locals.currentPath = '/alumni/membership'; %>
  <%- include('../partials/alumni-sidebar') %>

  <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4">
      <h1 class="text-xl font-bold" style="color:#1e3a5f">Memberships</h1>
      <p class="text-gray-500 text-sm">Purchase and manage your SVPM Alumni Association memberships</p>
    </div>

    <div class="p-4 sm:p-6 max-w-3xl">

      <!-- Flash messages -->
      <% if (locals.success_msg && success_msg.length > 0) { %>
      <div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm">
        <i class="fa-solid fa-circle-check"></i><span><%= success_msg %></span>
      </div>
      <% } %>
      <% if (locals.error_msg && error_msg.length > 0) { %>
      <div class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm">
        <i class="fa-solid fa-circle-exclamation"></i><span><%= error_msg %></span>
      </div>
      <% } %>

      <!-- Active Memberships Banner — shown if user has any paid membership -->
      <% if (payments && payments.length > 0) { %>
      <div class="bg-gradient-to-r from-emerald-500 to-emerald-600 rounded-2xl p-5 sm:p-6 mb-6 text-white">
        <div class="flex items-center gap-4 flex-wrap">
          <div class="w-14 h-14 rounded-2xl bg-white/20 flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-certificate text-3xl"></i>
          </div>
          <div class="flex-1">
            <h2 class="font-display text-xl sm:text-2xl font-bold">🎉 Active Member</h2>
            <p class="text-emerald-100 text-sm">
              You hold <strong><%= payments.length %></strong> membership<%= payments.length > 1 ? 's' : '' %> with SVPM Alumni Association
            </p>
          </div>
          <a href="/alumni/certificate" class="bg-white text-emerald-700 font-bold text-sm px-4 py-2.5 rounded-xl hover:bg-emerald-50 transition flex items-center gap-2 flex-shrink-0">
            <i class="fa-solid fa-download"></i> Certificate
          </a>
        </div>
      </div>
      <% } %>

      <!-- Benefits Section -->
      <div class="bg-white rounded-2xl border border-gray-100 p-5 sm:p-6 mb-6">
        <h3 class="font-bold text-navy-800 text-lg mb-5 flex items-center gap-2">
          <i class="fa-solid fa-star text-yellow-500"></i> Membership Benefits
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <% [
            { icon: 'fa-certificate', text: 'Official Membership Certificate (PDF)' },
            { icon: 'fa-address-book', text: 'Full access to Alumni Directory' },
            { icon: 'fa-calendar-days', text: 'Priority registration for events' },
            { icon: 'fa-id-card', text: 'Unique Member Badge on profile' },
            { icon: 'fa-receipt', text: 'Digital payment receipts' },
            { icon: 'fa-bell', text: 'Exclusive announcements & updates' }
          ].forEach(b => { %>
          <div class="flex items-center gap-3 p-3 rounded-xl bg-gray-50">
            <div class="w-8 h-8 rounded-lg bg-navy-100 flex items-center justify-center flex-shrink-0">
              <i class="fa-solid <%= b.icon %> text-navy-600 text-xs"></i>
            </div>
            <span class="text-gray-700 text-sm font-semibold"><%= b.text %></span>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- Plan Selector — always shown so users can buy additional plans -->
      <% if (plans && plans.length > 0) { %>
      <div class="mb-6">
        <h3 class="font-bold text-navy-800 text-xl mb-1">
          <%= payments && payments.length > 0 ? 'Switch or Upgrade Membership Plan' : 'Select a Membership Plan' %>
        </h3>
        <p class="text-gray-400 text-sm mb-4">
          <% if (payments && payments.length > 0) { %>
            Your active plan is highlighted. Select another plan to switch — payment creates a new active membership.
          <% } else { %>
            Choose a plan below and complete payment to activate your membership instantly.
          <% } %>
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <% plans.forEach(plan => {
               const planIdStr = plan._id.toString();
               const isActive = activePlanId === planIdStr;
               const isOwned  = ownedPlanIds.includes(planIdStr);
          %>
            <div class="plan-card bg-white rounded-2xl border-2 overflow-hidden flex flex-col cursor-pointer
                        <%= isActive ? 'border-emerald-400' : isOwned ? 'border-blue-300' : 'border-gray-200' %>"
                 id="card-<%= plan._id %>"
                 onclick="selectPlan('<%= plan._id %>', <%= plan.amount %>, '<%= plan.title.replace(/'/g, "\\'") %>')">
              <div class="p-5 flex-1 <%= plan.isFeatured ? 'bg-amber-50' : '' %>">
                <div class="flex items-center gap-2 mb-2 flex-wrap">
                  <% if (plan.isFeatured) { %><span class="text-xs badge-life px-2 py-1 rounded-full font-bold">Popular Choice</span><% } %>
                  <% if (isActive) { %><span class="text-xs bg-emerald-100 text-emerald-700 border border-emerald-200 px-2 py-1 rounded-full font-bold"><i class="fa-solid fa-circle-check mr-1"></i>Active Plan</span>
                  <% } else if (isOwned) { %><span class="text-xs bg-blue-100 text-blue-700 border border-blue-200 px-2 py-1 rounded-full font-bold"><i class="fa-solid fa-receipt mr-1"></i>Previously Purchased</span><% } %>
                </div>
                <h4 class="font-display font-bold text-xl text-navy-800 mb-2"><%= plan.title %></h4>
                <div class="text-gold-500 font-display font-bold text-3xl mb-3">₹<%= plan.amount.toLocaleString('en-IN') %></div>
                <p class="text-gray-500 text-sm mb-4"><%= plan.description %></p>
                <% if (plan.benefits && plan.benefits.length > 0) { %>
                  <ul class="space-y-1.5 text-xs text-gray-600">
                    <% plan.benefits.forEach(b => { %>
                      <li class="flex items-start gap-2"><i class="fa-solid fa-check text-emerald-500 mt-0.5"></i><%=b%></li>
                    <% }) %>
                  </ul>
                <% } %>
              </div>
              <div class="p-5 pt-0 mt-auto">
                <% if (isActive) { %>
                  <button type="button" id="btn-<%= plan._id %>"
                    class="plan-select-btn w-full text-center text-sm font-semibold text-white py-2.5 rounded-xl bg-emerald-500 border border-emerald-500 cursor-default">
                    <i class="fa-solid fa-circle-check mr-1"></i> Current Plan
                  </button>
                <% } else if (isOwned) { %>
                  <button type="button" id="btn-<%= plan._id %>"
                    onclick="selectPlan('<%= plan._id %>', <%= plan.amount %>, '<%= plan.title.replace(/'/g, "\\'") %>')"
                    class="plan-select-btn w-full text-center text-sm font-semibold text-blue-700 py-2.5 rounded-xl bg-blue-50 hover:bg-blue-100 transition border border-blue-200">
                    <i class="fa-solid fa-rotate mr-1"></i> Switch to This Plan
                  </button>
                <% } else { %>
                  <button type="button" id="btn-<%= plan._id %>"
                    onclick="selectPlan('<%= plan._id %>', <%= plan.amount %>, '<%= plan.title.replace(/'/g, "\\'") %>')"
                    class="plan-select-btn w-full text-center text-sm font-semibold text-navy-600 py-2.5 rounded-xl bg-navy-50 hover:bg-navy-100 transition border border-navy-100">
                    Select Plan
                  </button>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>

        <!-- Payment section (revealed after plan selection) -->
        <div id="payment-section" class="hidden bg-white rounded-2xl border border-gray-100 overflow-hidden">
          <div class="gradient-header p-5 flex items-center justify-between gap-4">
            <h3 class="text-white font-display font-bold text-lg" id="selected-plan-title">Plan Name</h3>
            <div class="text-gold-400 font-display font-bold text-2xl" id="selected-plan-amount">₹0</div>
          </div>
          <div class="p-5">
            <div class="flex items-center gap-3 mb-5 p-3 bg-blue-50 rounded-xl border border-blue-100">
              <i class="fa-solid fa-shield-halved text-blue-600 text-lg flex-shrink-0"></i>
              <div>
                <p class="text-blue-800 font-semibold text-sm">Secure Payment via Razorpay</p>
                <p class="text-blue-600 text-xs">UPI, Net Banking, Credit/Debit Card, Wallets accepted</p>
              </div>
            </div>
            <button id="pay-btn"
              class="w-full gradient-header text-white font-bold py-4 rounded-xl hover:opacity-90 transition text-base flex items-center justify-center gap-3">
              <i class="fa-solid fa-lock"></i>
              <span id="pay-btn-text">Pay & Buy Membership</span>
            </button>
            <p class="text-center text-gray-400 text-xs mt-3">
              <i class="fa-solid fa-info-circle mr-1"></i>
              Membership is activated instantly after successful payment.
            </p>
          </div>
        </div>
      </div>
      <% } else { %>
      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 text-center text-gray-500 mb-6">
        <i class="fa-solid fa-tags text-3xl mb-3 text-gray-300"></i>
        <p>No membership plans are currently available. Please check back later.</p>
      </div>
      <% } %>

      <!-- Membership Purchase History -->
      <% if (payments && payments.length > 0) { %>
      <div class="bg-white rounded-2xl border border-gray-100 p-5">
        <h4 class="font-bold text-navy-800 mb-4 flex items-center gap-2">
          <i class="fa-solid fa-receipt text-navy-600"></i> Membership Purchase History
          <span class="ml-auto text-xs font-normal text-gray-400"><%= payments.length %> purchase<%= payments.length > 1 ? 's' : '' %></span>
        </h4>
        <div class="space-y-3">
          <% payments.forEach((pmt, idx) => { %>
          <div class="border border-gray-100 rounded-xl p-4 <%= idx === 0 ? 'bg-emerald-50 border-emerald-200' : 'bg-gray-50' %>">
            <div class="flex items-start justify-between gap-3 flex-wrap">
              <div>
                <p class="font-semibold text-gray-800 text-sm">
                  <%= pmt.planTitle || (pmt.planId && pmt.planId.title) || 'Membership' %>
                  <% if (idx === 0) { %><span class="ml-2 text-xs badge-life px-2 py-0.5 rounded-full">Latest</span><% } %>
                </p>
                <p class="text-gray-400 text-xs font-mono mt-0.5"><%= pmt.receiptNumber %></p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="font-bold text-emerald-600 text-lg">₹<%= pmt.amount.toLocaleString('en-IN') %></p>
                <p class="text-gray-400 text-xs">
                  <%= pmt.paidAt ? new Date(pmt.paidAt).toLocaleDateString('en-IN', {year:'numeric',month:'short',day:'numeric'}) : '-' %>
                </p>
              </div>
            </div>
            <div class="mt-3 flex items-center gap-2 flex-wrap">
              <span class="text-xs font-semibold text-emerald-600 bg-emerald-100 px-2.5 py-1 rounded-full">
                <i class="fa-solid fa-circle-check mr-1"></i>Paid
              </span>
              <a href="/payments/receipt/<%= pmt._id %>"
                class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-lg transition"
                style="background:#1e3a5f;color:white;">
                <i class="fa-solid fa-download"></i> Receipt PDF
              </a>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
      <% } %>

    </div>
  </main>
</div>

<script>
const USER_NAME = '<%= user.name.replace(/'/g, "\\'") %>';
const USER_EMAIL = '<%= user.email %>';
const USER_PHONE = '<%= user.phone || "" %>';

// Server-rendered state — single source of truth
const OWNED_PLAN_IDS = new Set(<%- JSON.stringify(ownedPlanIds) %>);
const ACTIVE_PLAN_ID = <%- JSON.stringify(activePlanId) %>;

let selectedPlanId = null;
let selectedPlanAmount = 0;
let selectedPlanTitle = '';

function selectPlan(id, amount, title) {
  // Never allow re-selecting the already-active plan
  if (id === ACTIVE_PLAN_ID) return;

  selectedPlanId = id;
  selectedPlanAmount = amount;
  selectedPlanTitle = title;

  // Reset all non-active/non-owned cards
  document.querySelectorAll('.plan-card').forEach(c => {
    const planId = c.id.replace('card-', '');
    if (planId !== ACTIVE_PLAN_ID) c.classList.remove('selected');
  });
  document.querySelectorAll('.plan-select-btn').forEach(btn => {
    const planId = btn.id.replace('btn-', '');
    if (planId === ACTIVE_PLAN_ID) return; // leave active button alone
    if (OWNED_PLAN_IDS.has(planId) && planId !== id) {
      btn.innerHTML = '<i class="fa-solid fa-rotate mr-1"></i> Switch to This Plan';
      btn.className = 'plan-select-btn w-full text-center text-sm font-semibold text-blue-700 py-2.5 rounded-xl bg-blue-50 hover:bg-blue-100 transition border border-blue-200';
    } else if (planId !== id) {
      btn.textContent = 'Select Plan';
      btn.className = 'plan-select-btn w-full text-center text-sm font-semibold text-navy-600 py-2.5 rounded-xl bg-navy-50 hover:bg-navy-100 transition border border-navy-100';
    }
  });

  // Mark chosen card
  document.getElementById('card-' + id)?.classList.add('selected');
  const selectedBtn = document.getElementById('btn-' + id);
  if (selectedBtn) {
    selectedBtn.innerHTML = OWNED_PLAN_IDS.has(id)
      ? '<i class="fa-solid fa-rotate mr-1"></i> Selected — Switch ✓'
      : 'Selected ✓';
    selectedBtn.className = 'plan-select-btn w-full text-center text-sm font-semibold text-white py-2.5 rounded-xl bg-navy-700 border border-navy-700 transition';
  }

  document.getElementById('selected-plan-title').textContent = title;
  document.getElementById('selected-plan-amount').textContent = '₹' + amount.toLocaleString('en-IN');

  const isSwitch = OWNED_PLAN_IDS.has(id);
  document.getElementById('pay-btn-text').textContent = (isSwitch ? 'Switch to ' : 'Buy ') + title + ' — ₹' + amount.toLocaleString('en-IN');

  const section = document.getElementById('payment-section');
  section.classList.remove('hidden');
  section.scrollIntoView({ behavior: 'smooth', block: 'center' });
}

async function initiatePayment() {
  if (!selectedPlanId) {
    alert('Please select a membership plan first.');
    return;
  }
  if (selectedPlanId === ACTIVE_PLAN_ID) {
    alert('This is already your active membership plan.');
    return;
  }

  const btn = document.getElementById('pay-btn');
  const btnText = document.getElementById('pay-btn-text');
  btn.disabled = true;
  btnText.textContent = 'Creating order...';
  btn.querySelector('i').className = 'fa-solid fa-spinner fa-spin';

  const reset = () => {
    btn.disabled = false;
    const isSwitch = OWNED_PLAN_IDS.has(selectedPlanId);
    btnText.textContent = (isSwitch ? 'Switch to ' : 'Buy ') + selectedPlanTitle + ' — ₹' + selectedPlanAmount.toLocaleString('en-IN');
    btn.querySelector('i').className = 'fa-solid fa-lock';
  };

  try {
    const res = await fetch('/alumni/membership/apply', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ planId: selectedPlanId })
    });
    const data = await res.json();

    if (!data.success) {
      alert('Error: ' + data.message);
      return reset();
    }

    const options = {
      key: data.key,
      amount: data.amount,
      currency: data.currency || 'INR',
      name: 'SVPM Alumni Association',
      description: selectedPlanTitle + ' Membership',
      order_id: data.orderId,
      handler: async function(response) {
        btnText.textContent = 'Verifying payment...';
        try {
          const verifyRes = await fetch('/alumni/membership/verify-payment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              razorpay_order_id: response.razorpay_order_id,
              razorpay_payment_id: response.razorpay_payment_id,
              razorpay_signature: response.razorpay_signature,
              payment_id: data.paymentId
            })
          });
          const vData = await verifyRes.json();
          if (vData.success) {
            showToast(selectedPlanTitle);
            setTimeout(() => {
              window.location.href = '/alumni/membership?success=1';
            }, 2500);
          } else {
            alert('Payment verification failed: ' + vData.message + '\nPlease contact admin with your payment ID: ' + response.razorpay_payment_id);
            reset();
          }
        } catch (err) {
          alert('Verification error: ' + err.message);
          reset();
        }
      },
      prefill: { name: USER_NAME, email: USER_EMAIL, contact: USER_PHONE },
      theme: { color: '#1e3a5f' },
      modal: { ondismiss: () => reset() }
    };

    const rzp = new window.Razorpay(options);
    rzp.on('payment.failed', function (response) {
      alert('Payment failed: ' + response.error.description);
      reset();
    });
    rzp.open();

  } catch (err) {
    alert('Request failed: ' + err.message);
    reset();
  }
}

function showToast(planName) {
  const toast = document.createElement('div');
  toast.className = 'fixed bottom-4 right-4 bg-emerald-500 text-white px-6 py-4 rounded-xl shadow-2xl flex items-center gap-3 z-50';
  toast.innerHTML = `<i class="fa-solid fa-circle-check text-xl"></i><div><h4 class="font-bold">Membership Activated!</h4><p class="text-sm opacity-90">${planName} is now your active plan.</p></div>`;
  document.body.appendChild(toast);
  setTimeout(() => toast.remove(), 5000);
}

// Show success toast from URL param
const urlParams = new URLSearchParams(window.location.search);
if (urlParams.get('success') === '1') {
  showToast('Your new');
  // Clean URL without reload
  history.replaceState({}, '', '/alumni/membership');
}

const payBtnElement = document.getElementById('pay-btn');
if (payBtnElement) {
  payBtnElement.addEventListener('click', initiatePayment);
}
</script>
</body>
</html>
