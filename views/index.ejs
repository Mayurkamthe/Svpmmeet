<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: { 50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32' },
            gold: { 400:'#f5c842',500:'#e8b820',600:'#c8a31a' }
          },
          fontFamily: {
            display: ['"Playfair Display"', 'Georgia', 'serif'],
            body: ['"Source Sans 3"', 'system-ui', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
  <style>
    body { font-family: 'Source Sans 3', system-ui, sans-serif; }
    .font-display { font-family: 'Playfair Display', Georgia, serif; }
    .gradient-header { background: linear-gradient(135deg, #0f1e32 0%, #1e3a5f 50%, #2d6a9f 100%); }
    .hero-bg {
      background: linear-gradient(135deg, #0f1e32 0%, #1e3a5f 60%, #2d6a9f 100%);
      position: relative;
      overflow: hidden;
    }
    .hero-bg::before {
      content: '';
      position: absolute; inset: 0;
      background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    }
    .stat-card { background: rgba(255,255,255,0.08); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.12); }
    .badge-life { background: linear-gradient(135deg, #f5c842, #c8a31a); color: #1a1a1a; }
    .card-hover { transition: transform 0.2s, box-shadow 0.2s; }
    .card-hover:hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(0,0,0,0.15); }
  </style>
</head>
<body class="bg-gray-50 text-gray-800">

  <!-- Navbar -->
  <%- include('partials/navbar') %>

  <!-- Hero -->
  <section class="hero-bg py-14 sm:py-24 px-4">
    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <div class="inline-flex items-center gap-2 bg-gold-500/20 border border-gold-500/40 text-gold-400 text-xs font-bold px-4 py-2 rounded-full mb-6 uppercase tracking-widest">
            <i class="fa-solid fa-graduation-cap"></i>
            Est. Alumni Association
          </div>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            SVPM College<br>
            <span class="text-gold-400">Alumni</span><br>
            Association
          </h1>
          <p class="text-navy-200 text-lg leading-relaxed mb-8">
            Reconnect, grow and celebrate your journey with fellow alumni of
            <strong class="text-white">SVPM College of Engineering, Malegaon Bk, Baramati</strong>.
            Join us and become a Life Member today.
          </p>
          <div class="flex flex-wrap gap-4">
            <a href="/auth/register" class="bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold px-7 py-3.5 rounded-xl transition text-base shadow-lg shadow-gold-500/30">
              <i class="fa-solid fa-user-plus mr-2"></i>Register Now
            </a>
            <a href="/events" class="bg-white/10 hover:bg-white/20 text-white border border-white/20 font-semibold px-7 py-3.5 rounded-xl transition text-base backdrop-blur-sm">
              <i class="fa-solid fa-calendar-days mr-2"></i>View Events
            </a>
          </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 gap-4">
          <div class="stat-card rounded-2xl p-6 text-center">
            <div class="text-4xl font-display font-bold text-gold-400">500+</div>
            <div class="text-navy-300 text-sm mt-1 font-semibold">Registered Alumni</div>
          </div>
          <div class="stat-card rounded-2xl p-6 text-center">
            <div class="text-4xl font-display font-bold text-gold-400">12+</div>
            <div class="text-navy-300 text-sm mt-1 font-semibold">Batches</div>
          </div>
          <div class="stat-card rounded-2xl p-6 text-center">
            <div class="text-4xl font-display font-bold text-gold-400">50+</div>
            <div class="text-navy-300 text-sm mt-1 font-semibold">Life Members</div>
          </div>
          <div class="stat-card rounded-2xl p-6 text-center">
            <div class="text-4xl font-display font-bold text-gold-400">20+</div>
            <div class="text-navy-300 text-sm mt-1 font-semibold">Events Hosted</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="py-12 sm:py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-display text-4xl font-bold text-navy-800 mb-3">Member Benefits</h2>
        <p class="text-gray-500 text-lg">Everything you need to stay connected with your alma mater</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% const features = [
          { icon: 'fa-id-card', color: 'text-blue-600 bg-blue-50', title: 'Life Membership', desc: 'Apply for lifetime membership with a one-time fee and get exclusive benefits.' },
          { icon: 'fa-address-book', color: 'text-emerald-600 bg-emerald-50', title: 'Alumni Directory', desc: 'Connect with thousands of fellow alumni across industries and geographies.' },
          { icon: 'fa-certificate', color: 'text-amber-600 bg-amber-50', title: 'Digital Certificate', desc: 'Download your life membership certificate as a professional PDF.' },
          { icon: 'fa-calendar-days', color: 'text-purple-600 bg-purple-50', title: 'Exclusive Events', desc: 'Attend reunions, seminars, and networking events organized for alumni.' },
          { icon: 'fa-receipt', color: 'text-rose-600 bg-rose-50', title: 'Payment History', desc: 'Track all your transactions with instant PDF receipts.' },
          { icon: 'fa-bell', color: 'text-cyan-600 bg-cyan-50', title: 'Announcements', desc: 'Stay updated with the latest news and announcements from SVPM.' }
        ]; %>
        <% features.forEach(f => { %>
        <div class="card-hover bg-gray-50 border border-gray-100 rounded-2xl p-6">
          <div class="w-12 h-12 rounded-xl <%= f.color %> flex items-center justify-center mb-4">
            <i class="fa-solid <%= f.icon %> text-xl"></i>
          </div>
          <h3 class="text-navy-800 font-bold text-lg mb-2"><%= f.title %></h3>
          <p class="text-gray-500 text-sm leading-relaxed"><%= f.desc %></p>
        </div>
        <% }) %>
      </div>
    </div>
  </section>

  <!-- Upcoming Events -->
  <% if (events && events.length > 0) { %>
  <section class="py-12 sm:py-20 px-4 bg-navy-900">
    <div class="max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-12">
        <div>
          <h2 class="font-display text-4xl font-bold text-white mb-2">Upcoming Events</h2>
          <p class="text-navy-400">Don't miss out on these upcoming events</p>
        </div>
        <a href="/events" class="text-gold-400 hover:text-gold-300 font-semibold text-sm flex items-center gap-2">
          View all <i class="fa-solid fa-arrow-right"></i>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <% events.forEach(event => { %>
        <div class="card-hover bg-white/5 border border-white/10 rounded-2xl overflow-hidden">
          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-gold-500/20 text-gold-400 border border-gold-500/30 px-2.5 py-1 rounded-full font-semibold capitalize"><%= event.type %></span>
              <% if (event.isFree) { %><span class="text-xs bg-emerald-500/20 text-emerald-400 border border-emerald-500/30 px-2.5 py-1 rounded-full font-semibold">Free</span><% } %>
            </div>
            <h3 class="text-white font-bold text-lg mb-2"><%= event.title %></h3>
            <p class="text-navy-300 text-sm line-clamp-2 mb-4"><%= event.description %></p>
            <div class="flex items-center gap-2 text-navy-400 text-xs mb-1">
              <i class="fa-solid fa-calendar"></i>
              <%= new Date(event.date).toLocaleDateString('en-IN', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %>
            </div>
            <div class="flex items-center gap-2 text-navy-400 text-xs">
              <i class="fa-solid fa-location-dot"></i> <%= event.venue %>
            </div>
          </div>
          <div class="px-5 pb-5">
            <a href="/events/<%= event._id %>" class="block text-center bg-navy-700 hover:bg-navy-600 text-white font-semibold text-sm py-2.5 rounded-xl transition">
              View Details
            </a>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- Announcements -->
  <% if (announcements && announcements.length > 0) { %>
  <section class="py-12 sm:py-20 px-4 bg-white">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-display text-4xl font-bold text-navy-800 mb-3">Latest Announcements</h2>
      </div>
      <div class="space-y-4 max-w-3xl mx-auto">
        <% announcements.forEach(a => { %>
        <div class="flex items-start gap-4 bg-gray-50 border border-gray-100 rounded-xl p-5 card-hover">
          <div class="w-10 h-10 rounded-full bg-navy-100 flex items-center justify-center flex-shrink-0">
            <i class="fa-solid fa-bullhorn text-navy-600"></i>
          </div>
          <div class="flex-1">
            <div class="flex items-center gap-2 mb-1">
              <h4 class="text-navy-800 font-bold text-base"><%= a.title %></h4>
              <span class="text-xs bg-navy-100 text-navy-600 px-2 py-0.5 rounded-full capitalize"><%= a.type %></span>
            </div>
            <p class="text-gray-500 text-sm leading-relaxed"><%= a.content.substring(0, 150) %><%= a.content.length > 150 ? '...' : '' %></p>
            <div class="text-gray-400 text-xs mt-2">
              <i class="fa-regular fa-clock"></i>
              <%= new Date(a.createdAt).toLocaleDateString('en-IN', { year: 'numeric', month: 'short', day: 'numeric' }) %>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </section>
  <% } %>

  <!-- CTA Banner -->
  <section class="py-16 px-4 hero-bg">
    <div class="max-w-3xl mx-auto text-center relative z-10">
      <i class="fa-solid fa-graduation-cap text-gold-400 text-5xl mb-6"></i>
      <h2 class="font-display text-4xl font-bold text-white mb-4">Ready to Join?</h2>
      <p class="text-navy-200 text-lg mb-8">Register as an alumni and become part of the SVPM family. Apply for Life Membership and stay connected forever.</p>
      <a href="/auth/register" class="inline-block bg-gold-500 hover:bg-gold-400 text-navy-900 font-bold px-10 py-4 rounded-xl text-lg transition shadow-xl shadow-gold-500/30">
        <i class="fa-solid fa-user-plus mr-2"></i>Join Today — Free Registration
      </a>
    </div>
  </section>

  <%- include('partials/footer') %>

  <!-- Flash Messages -->
  <% if (locals.success_msg && success_msg.length > 0) { %>
  <div class="fixed top-5 right-5 z-50 flex items-center gap-3 bg-emerald-600 text-white px-5 py-3 rounded-xl shadow-xl text-sm font-semibold max-w-sm">
    <i class="fa-solid fa-circle-check"></i><span><%= success_msg %></span>
  </div>
  <% } %>
  <% if (locals.error_msg && error_msg.length > 0) { %>
  <div class="fixed top-5 right-5 z-50 flex items-center gap-3 bg-red-600 text-white px-5 py-3 rounded-xl shadow-xl text-sm font-semibold max-w-sm">
    <i class="fa-solid fa-circle-exclamation"></i><span><%= error_msg %></span>
  </div>
  <% } %>
</body>
</html>
