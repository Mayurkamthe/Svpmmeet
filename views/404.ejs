<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"/><title>404</title><script src="https://cdn.tailwindcss.com"></script><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/><style>body{font-family:system-ui,sans-serif;background:linear-gradient(135deg,#0f1e32,#1e3a5f,#2d6a9f);}</style></head>
<body class="min-h-screen flex items-center justify-center px-4 text-center">
  <div class="max-w-md">
    <div class="text-8xl font-bold text-white/10 mb-4">404</div>
    <i class="fa-solid fa-map-location-dot text-5xl text-yellow-400 mb-5 block"></i>
    <h1 class="text-3xl font-bold text-white mb-3">Page Not Found</h1>
    <p class="text-blue-200 mb-8">The page you're looking for doesn't exist.</p>
    <div class="flex gap-4 justify-center">
      <a href="/" class="bg-yellow-400 hover:bg-yellow-300 text-gray-900 font-bold px-6 py-3 rounded-xl transition"><i class="fa-solid fa-home mr-2"></i>Go Home</a>
      <a href="javascript:history.back()" class="bg-white/10 hover:bg-white/20 text-white border border-white/20 font-semibold px-6 py-3 rounded-xl transition"><i class="fa-solid fa-arrow-left mr-2"></i>Back</a>
    </div>
  </div>
</body>
</html>
