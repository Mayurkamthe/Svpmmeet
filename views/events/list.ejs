<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{400:'#f5c842',500:'#e8b820',600:'#c8a31a'}}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.card-hover{transition:transform 0.2s,box-shadow 0.2s;}.card-hover:hover{transform:translateY(-3px);box-shadow:0 12px 30px rgba(0,0,0,0.12);}.badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}</style>
</head>
<body class="bg-gray-50">
  <%- include('../partials/navbar') %>
  <section class="gradient-header py-16 px-4 text-center">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-display text-4xl font-bold text-white mb-3">SVPM Alumni Events</h1>
      <p class="text-navy-200 text-lg">Reunions, seminars, and networking events for our community</p>
    </div>
  </section>
  <div class="max-w-6xl mx-auto px-4 py-8 sm:py-12">
    <% if(upcoming&&upcoming.length>0){%>
    <div class="mb-14">
      <h2 class="font-display text-2xl font-bold mb-6" style="color:#1e3a5f">Upcoming Events</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%upcoming.forEach(event=>{%>
        <div class="card-hover bg-white rounded-2xl border border-gray-100 overflow-hidden">
          <div class="p-4 flex items-center justify-between" style="background:linear-gradient(135deg,#0f1e32,#2d6a9f)">
            <div><div class="text-yellow-400 font-bold text-xs uppercase tracking-wider mb-1"><%=event.type%></div><div class="text-white font-bold text-lg"><%=event.title%></div></div>
            <div class="text-right text-white"><div class="text-3xl font-bold leading-none"><%=new Date(event.date).getDate()%></div><div class="text-blue-300 text-xs uppercase font-bold"><%=new Date(event.date).toLocaleString('en-IN',{month:'short'})%></div></div>
          </div>
          <div class="p-5">
            <p class="text-gray-500 text-sm mb-4 line-clamp-3"><%=event.description%></p>
            <div class="space-y-1.5 mb-4 text-xs text-gray-500">
              <div class="flex items-center gap-2"><i class="fa-solid fa-clock w-4" style="color:#2d6a9f"></i><%=new Date(event.date).toLocaleString('en-IN',{weekday:'short',hour:'2-digit',minute:'2-digit'})%></div>
              <div class="flex items-center gap-2"><i class="fa-solid fa-location-dot w-4" style="color:#2d6a9f"></i><%=event.venue%></div>
              <%if(!event.isFree){%><div class="flex items-center gap-2 font-semibold text-amber-700"><i class="fa-solid fa-indian-rupee-sign w-4"></i>Fee: ₹<%=event.fee%></div><%}else{%><div class="flex items-center gap-2 font-semibold text-emerald-600"><i class="fa-solid fa-check w-4"></i>Free Event</div><%}%>
            </div>
            <a href="/events/<%=event._id%>" class="block text-center text-white font-bold text-sm py-2.5 rounded-xl hover:opacity-90 transition" style="background:#1e3a5f">View & Register</a>
          </div>
        </div>
        <%})%>
      </div>
    </div>
    <%}else{%>
    <div class="text-center py-16 bg-white rounded-2xl border border-gray-100 mb-14"><i class="fa-solid fa-calendar text-5xl text-gray-200 mb-4 block"></i><h3 class="text-gray-500 font-semibold text-lg">No upcoming events</h3><p class="text-gray-400 text-sm mt-1">Check back soon!</p></div>
    <%}%>
    <%if(past&&past.length>0){%>
    <div>
      <h2 class="font-display text-2xl font-bold mb-6 text-gray-600">Past Events</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <%past.forEach(event=>{%>
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden opacity-75">
          <div class="bg-gray-200 p-4 flex items-center justify-between">
            <div><div class="text-gray-500 font-bold text-xs uppercase mb-1"><%=event.type%></div><div class="text-gray-700 font-bold text-lg"><%=event.title%></div></div>
            <div class="text-right text-gray-600"><div class="text-2xl font-bold"><%=new Date(event.date).getDate()%></div><div class="text-gray-400 text-xs uppercase font-bold"><%=new Date(event.date).toLocaleString('en-IN',{month:'short',year:'numeric'})%></div></div>
          </div>
          <div class="p-5">
            <p class="text-gray-500 text-sm line-clamp-2 mb-3"><%=event.description%></p>
            <div class="text-gray-400 text-xs mb-4"><i class="fa-solid fa-location-dot mr-1"></i><%=event.venue%></div>
            <a href="/events/<%=event._id%>" class="block text-center text-gray-600 font-semibold text-sm py-2 rounded-xl bg-gray-100 hover:bg-gray-200 transition">View Summary</a>
          </div>
        </div>
        <%})%>
      </div>
    </div>
    <%}%>
  </div>
  <%- include('../partials/footer') %>
</body>
</html>
