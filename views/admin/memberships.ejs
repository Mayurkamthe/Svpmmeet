<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{400:'#f5c842',500:'#e8b820',600:'#c8a31a'}}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>
    body{font-family:'Source Sans 3',system-ui,sans-serif;}
    .gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}
    .sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}
    .sidebar-link:hover{background:rgba(255,255,255,0.1);}
    .badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}
  </style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen">
  <% locals.currentPath = '/admin/memberships'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4 sticky top-0 z-10">
      <h1 class="text-xl font-bold" style="color:#1e3a5f">Membership Purchases</h1>
      <p class="text-gray-500 text-sm">All paid membership transactions — one row per purchase</p>
    </div>
    <div class="p-4 sm:p-6">

      <!-- Summary stat -->
      <div class="mb-5 flex items-center gap-3">
        <div class="bg-white border border-gray-100 rounded-xl px-5 py-3 flex items-center gap-3">
          <i class="fa-solid fa-receipt text-navy-600"></i>
          <div>
            <p class="text-xs text-gray-400 uppercase font-bold">Total Purchases</p>
            <p class="font-bold text-navy-800 text-lg"><%= payments ? payments.length : 0 %></p>
          </div>
        </div>
        <div class="bg-white border border-gray-100 rounded-xl px-5 py-3 flex items-center gap-3">
          <i class="fa-solid fa-indian-rupee-sign text-emerald-600"></i>
          <div>
            <p class="text-xs text-gray-400 uppercase font-bold">Total Revenue</p>
            <p class="font-bold text-emerald-700 text-lg">
              ₹<%= payments ? payments.reduce((s,p) => s + (p.amount||0), 0).toLocaleString('en-IN') : 0 %>
            </p>
          </div>
        </div>
      </div>

      <% if (locals.success_msg && success_msg.length > 0) { %>
      <div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm">
        <i class="fa-solid fa-circle-check"></i><span><%= success_msg %></span>
      </div>
      <% } %>

      <!-- Desktop Table -->
      <div class="hidden sm:block bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Alumni</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Alumni ID</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Plan</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Amount</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Date</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Receipt</th>
                <th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              <% if (payments && payments.length > 0) { payments.forEach(pmt => { %>
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-4">
                  <div class="flex items-center gap-3">
                    <div class="w-9 h-9 rounded-xl bg-blue-50 flex items-center justify-center flex-shrink-0 font-bold text-blue-700 text-sm overflow-hidden">
                      <% if (pmt.user && pmt.user.avatar) { %><img src="<%= pmt.user.avatar %>" class="w-full h-full object-cover"><% } else { %><%= pmt.user ? pmt.user.name.charAt(0) : '?' %><% } %>
                    </div>
                    <div>
                      <p class="font-semibold text-gray-800"><%= pmt.user ? pmt.user.name : 'Unknown' %></p>
                      <p class="text-gray-400 text-xs"><%= pmt.user ? pmt.user.email : '' %></p>
                    </div>
                  </div>
                </td>
                <td class="px-5 py-4 font-mono text-xs text-gray-500"><%= pmt.user ? (pmt.user.alumniId || 'N/A') : 'N/A' %></td>
                <td class="px-5 py-4">
                  <span class="text-xs badge-life px-2.5 py-1 rounded-full font-semibold">
                    <%= pmt.planTitle || (pmt.planId && pmt.planId.title) || 'Membership' %>
                  </span>
                </td>
                <td class="px-5 py-4 font-bold text-emerald-600">₹<%= pmt.amount.toLocaleString('en-IN') %></td>
                <td class="px-5 py-4 text-gray-500 text-xs">
                  <%= pmt.paidAt ? new Date(pmt.paidAt).toLocaleDateString('en-IN', {year:'numeric',month:'short',day:'numeric'}) : '-' %>
                </td>
                <td class="px-5 py-4 font-mono text-xs text-gray-400"><%= pmt.receiptNumber %></td>
                <td class="px-5 py-4">
                  <div class="flex items-center gap-2">
                    <a href="mailto:<%= pmt.user ? pmt.user.email : '' %>" class="text-xs bg-blue-50 text-blue-600 border border-blue-200 px-2 py-1.5 rounded-lg hover:bg-blue-100" title="Email">
                      <i class="fa-solid fa-envelope"></i>
                    </a>
                    <a href="/payments/receipt/<%= pmt._id %>" class="text-xs bg-gray-50 text-gray-600 border border-gray-200 px-2 py-1.5 rounded-lg hover:bg-gray-100" title="Receipt PDF">
                      <i class="fa-solid fa-receipt"></i>
                    </a>
                  </div>
                </td>
              </tr>
              <% }) } else { %>
              <tr>
                <td colspan="7" class="px-5 py-12 text-center text-gray-400">
                  <i class="fa-solid fa-id-card text-3xl mb-2 block text-gray-200"></i>
                  No membership purchases yet
                </td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Mobile Cards -->
      <div class="sm:hidden space-y-3">
        <% if (payments && payments.length > 0) { payments.forEach(pmt => { %>
        <div class="bg-white rounded-2xl border border-gray-100 p-4">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-blue-50 flex items-center justify-center font-bold text-blue-700 overflow-hidden flex-shrink-0">
              <% if (pmt.user && pmt.user.avatar) { %><img src="<%= pmt.user.avatar %>" class="w-full h-full object-cover"><% } else { %><%= pmt.user ? pmt.user.name.charAt(0) : '?' %><% } %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-800 truncate"><%= pmt.user ? pmt.user.name : 'Unknown' %></p>
              <p class="text-gray-400 text-xs"><%= pmt.user ? (pmt.user.alumniId || pmt.user.email) : '' %></p>
            </div>
            <span class="text-xs badge-life px-2 py-1 rounded-full font-semibold flex-shrink-0">
              <%= pmt.planTitle || (pmt.planId && pmt.planId.title) || 'Membership' %>
            </span>
          </div>
          <div class="bg-emerald-50 border border-emerald-100 rounded-xl p-3 mb-3 text-xs flex items-center justify-between">
            <span class="font-bold text-emerald-700">₹<%= pmt.amount.toLocaleString('en-IN') %></span>
            <span class="text-emerald-600"><%= pmt.paidAt ? new Date(pmt.paidAt).toLocaleDateString('en-IN') : '-' %></span>
          </div>
          <p class="text-xs font-mono text-gray-400 mb-3"><%= pmt.receiptNumber %></p>
          <div class="flex gap-2">
            <a href="mailto:<%= pmt.user ? pmt.user.email : '' %>" class="flex-1 text-center text-sm bg-blue-50 text-blue-600 border border-blue-200 font-semibold py-2 rounded-xl">
              <i class="fa-solid fa-envelope mr-1"></i>Email
            </a>
            <a href="/payments/receipt/<%= pmt._id %>" class="flex-1 text-center text-sm bg-gray-50 text-gray-600 border border-gray-200 font-semibold py-2 rounded-xl">
              <i class="fa-solid fa-receipt mr-1"></i>Receipt
            </a>
          </div>
        </div>
        <% }) } else { %>
        <div class="text-center py-12 bg-white rounded-2xl border border-gray-100">
          <i class="fa-solid fa-id-card text-4xl text-gray-200 mb-3 block"></i>
          <p class="text-gray-400 font-semibold">No membership purchases yet</p>
        </div>
        <% } %>
      </div>

    </div>
  </main>
</div>
</body>
</html>
