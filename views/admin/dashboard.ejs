<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{400:'#f5c842',500:'#e8b820',600:'#c8a31a'}},fontFamily:{display:['"Playfair Display"','Georgia','serif']}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>
    body{font-family:'Source Sans 3',system-ui,sans-serif;}
    .gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}
    .sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}
    .sidebar-link:hover{background:rgba(255,255,255,0.1);}
    .badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}
    .card-hover{transition:transform 0.2s,box-shadow 0.2s;}
    .card-hover:hover{transform:translateY(-2px);box-shadow:0 8px 25px rgba(0,0,0,0.1);}
  </style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen">
  <% locals.currentPath = '/admin/dashboard'; %>
  <%- include('../partials/admin-sidebar') %>

  <main class="flex-1 overflow-y-auto">
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex items-center justify-between sticky top-0 z-10">
      <div>
        <h1 class="text-xl font-bold text-navy-800">Admin Dashboard</h1>
        <p class="text-gray-500 text-sm">SVPM Alumni Association</p>
      </div>
      <span class="text-gray-400 text-sm"><i class="fa-solid fa-calendar mr-1"></i><%= new Date().toLocaleDateString('en-IN',{weekday:'short',year:'numeric',month:'short',day:'numeric'}) %></span>
    </div>

    <div class="p-6">
      <% if (locals.success_msg && success_msg.length>0) { %>
      <div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-check"></i><%= success_msg %></div>
      <% } %>

      <!-- Stats -->
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-6">
        <div class="rounded-2xl p-5 text-white card-hover" style="background:linear-gradient(135deg,#1e3a5f,#2d6a9f)">
          <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center mb-3"><i class="fa-solid fa-users text-xl"></i></div>
          <div class="text-3xl font-display font-bold"><%= stats.totalAlumni %></div>
          <div class="text-white/70 text-xs mt-1 font-semibold">Total Alumni</div>
        </div>
        <div class="bg-white rounded-2xl p-5 border border-gray-100 card-hover">
          <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center mb-3"><i class="fa-solid fa-clock text-amber-600"></i></div>
          <div class="text-3xl font-display font-bold text-navy-800"><%= stats.pendingAlumni %></div>
          <div class="text-gray-400 text-xs mt-1 font-semibold">Pending Approval</div>
        </div>
        <div class="rounded-2xl p-5 text-white card-hover" style="background:linear-gradient(135deg,#064e3b,#059669)">
          <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center mb-3"><i class="fa-solid fa-user-check text-xl"></i></div>
          <div class="text-3xl font-display font-bold"><%= stats.approvedAlumni %></div>
          <div class="text-white/70 text-xs mt-1 font-semibold">Active Members</div>
        </div>
        <div class="rounded-2xl p-5 text-white card-hover" style="background:linear-gradient(135deg,#3b0764,#7c3aed)">
          <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center mb-3"><i class="fa-solid fa-star text-xl"></i></div>
          <div class="text-3xl font-display font-bold"><%= stats.lifeMembers %></div>
          <div class="text-white/70 text-xs mt-1 font-semibold">Life Members</div>
        </div>
        <div class="rounded-2xl p-5 text-white card-hover" style="background:linear-gradient(135deg,#78350f,#d97706)">
          <div class="w-10 h-10 rounded-xl bg-white/15 flex items-center justify-center mb-3"><i class="fa-solid fa-indian-rupee-sign text-xl"></i></div>
          <div class="text-2xl font-display font-bold">₹<%= stats.revenue.toLocaleString('en-IN') %></div>
          <div class="text-white/70 text-xs mt-1 font-semibold">Total Revenue</div>
        </div>
      </div>

      <!-- Alert for pending -->
      <% if (stats.pendingAlumni > 0) { %>
      <div class="bg-amber-50 border border-amber-200 rounded-2xl p-4 mb-6 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center"><i class="fa-solid fa-bell text-amber-600"></i></div>
          <div>
            <p class="font-bold text-amber-800"><%= stats.pendingAlumni %> alumni awaiting approval</p>
            <p class="text-amber-600 text-xs">Review and approve new registrations</p>
          </div>
        </div>
        <a href="/admin/alumni?status=pending" class="bg-amber-600 hover:bg-amber-700 text-white font-bold text-sm px-4 py-2 rounded-xl transition">Review Now</a>
      </div>
      <% } %>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-6">
        <!-- Recent Registrations -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-gray-100 p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-navy-800 flex items-center gap-2"><i class="fa-solid fa-user-plus text-navy-600"></i> Recent Registrations</h3>
            <a href="/admin/alumni" class="text-navy-600 text-xs font-semibold hover:text-navy-800">View All</a>
          </div>
          <div class="space-y-2">
            <% if (recentAlumni && recentAlumni.length > 0) { %>
            <% recentAlumni.forEach(a => { %>
            <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50 transition" id="alumni-row-<%= a._id %>">
              <div class="w-9 h-9 rounded-xl bg-navy-100 flex items-center justify-center flex-shrink-0 overflow-hidden">
                <% if (a.avatar) { %><img src="<%= a.avatar %>" class="w-full h-full object-cover"><% } else { %><span class="text-navy-700 font-bold text-sm"><%= a.name.charAt(0) %></span><% } %>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-800 text-sm truncate"><%= a.name %></p>
                <p class="text-gray-400 text-xs"><%= a.profile?.branch %> &bull; Batch <%= a.profile?.passOutYear %></p>
              </div>
              <div class="flex items-center gap-2 flex-shrink-0">
                <span class="text-xs font-mono text-gray-400"><%= a.alumniId %></span>
                <% if (!a.isVerified) { %>
                <button onclick="approveAlumni('<%= a._id %>', this)" class="text-xs bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 font-semibold px-2 py-1 rounded-lg transition">
                  <i class="fa-solid fa-check mr-1"></i>Approve
                </button>
                <% } else { %>
                <span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-lg font-semibold"><i class="fa-solid fa-check mr-1"></i>Verified</span>
                <% } %>
              </div>
            </div>
            <% }) %>
            <% } else { %>
            <div class="text-center py-6 text-gray-400 text-sm"><i class="fa-solid fa-users text-2xl mb-2 block text-gray-200"></i>No recent registrations</div>
            <% } %>
          </div>
        </div>

        <!-- Pending Memberships -->
        <div class="bg-white rounded-2xl border border-gray-100 p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-navy-800 flex items-center gap-2"><i class="fa-solid fa-id-card text-navy-600"></i> Membership</h3>
            <a href="/admin/memberships" class="text-navy-600 text-xs font-semibold hover:text-navy-800">View All</a>
          </div>
          <% if (pendingMemberships && pendingMemberships.length > 0) { %>
          <div class="space-y-3">
            <% pendingMemberships.forEach(m => { %>
            <div class="p-3 bg-amber-50 border border-amber-100 rounded-xl" id="mem-row-<%= m._id %>">
              <div class="flex items-center justify-between mb-0.5">
                <span class="font-semibold text-gray-800 text-sm"><%= m.name %></span>
                <span class="text-xs font-mono text-gray-400"><%= m.alumniId %></span>
              </div>
              <p class="text-gray-500 text-xs mb-2"><%= m.profile?.branch %> &bull; <%= m.profile?.passOutYear %></p>
              <div class="flex gap-2">
                <button onclick="approveMembership('<%= m._id %>', this)" class="flex-1 text-xs bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-1.5 rounded-lg transition">
                  <i class="fa-solid fa-check mr-1"></i>Approve
                </button>
                <button onclick="rejectMembership('<%= m._id %>')" class="flex-1 text-xs bg-red-50 hover:bg-red-100 text-red-600 border border-red-200 font-semibold py-1.5 rounded-lg transition">
                  <i class="fa-solid fa-xmark mr-1"></i>Reject
                </button>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="text-center py-8 text-gray-400 text-sm"><i class="fa-solid fa-id-card text-2xl mb-2 block text-gray-200"></i>No pending requests</div>
          <% } %>
        </div>
      </div>

      <!-- Recent Payments + Upcoming Events -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="bg-white rounded-2xl border border-gray-100 p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-navy-800 flex items-center gap-2"><i class="fa-solid fa-indian-rupee-sign text-navy-600"></i> Recent Payments</h3>
            <a href="/admin/payments" class="text-navy-600 text-xs font-semibold">View All</a>
          </div>
          <% if (recentPayments && recentPayments.length > 0) { %>
          <div class="space-y-2">
            <% recentPayments.forEach(p => { %>
            <div class="flex items-center gap-3 p-3 rounded-xl hover:bg-gray-50">
              <div class="w-8 h-8 rounded-lg bg-emerald-50 flex items-center justify-center flex-shrink-0"><i class="fa-solid fa-indian-rupee-sign text-emerald-600 text-xs"></i></div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-800 text-sm truncate"><%= p.user?.name %></p>
                <p class="text-gray-400 text-xs capitalize"><%= p.purpose?.replace(/_/g,' ') %></p>
              </div>
              <div class="text-right">
                <p class="font-bold text-emerald-600 text-sm">₹<%= p.amount.toLocaleString('en-IN') %></p>
                <p class="text-gray-400 text-xs"><%= p.paidAt ? new Date(p.paidAt).toLocaleDateString('en-IN',{month:'short',day:'numeric'}) : '-' %></p>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="text-center py-6 text-gray-400 text-sm"><i class="fa-solid fa-receipt text-2xl mb-2 block text-gray-200"></i>No payments yet</div>
          <% } %>
        </div>

        <div class="bg-white rounded-2xl border border-gray-100 p-5">
          <div class="flex items-center justify-between mb-4">
            <h3 class="font-bold text-navy-800 flex items-center gap-2"><i class="fa-solid fa-calendar-days text-navy-600"></i> Upcoming Events</h3>
            <a href="/admin/events" class="text-navy-600 text-xs font-semibold">Manage</a>
          </div>
          <% if (upcomingEvents && upcomingEvents.length > 0) { %>
          <div class="space-y-3">
            <% upcomingEvents.forEach(e => { %>
            <div class="flex items-start gap-3 p-3 rounded-xl hover:bg-gray-50">
              <div class="w-12 h-12 rounded-xl bg-navy-700 flex flex-col items-center justify-center flex-shrink-0 text-white">
                <span class="text-xs font-bold uppercase leading-tight"><%= new Date(e.date).toLocaleString('en-IN',{month:'short'}) %></span>
                <span class="text-lg font-display font-bold leading-tight"><%= new Date(e.date).getDate() %></span>
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-semibold text-gray-800 text-sm truncate"><%= e.title %></p>
                <p class="text-gray-400 text-xs"><i class="fa-solid fa-location-dot mr-1"></i><%= e.venue %></p>
              </div>
            </div>
            <% }) %>
          </div>
          <% } else { %>
          <div class="text-center py-6 text-gray-400 text-sm"><i class="fa-solid fa-calendar text-2xl mb-2 block text-gray-200"></i>No upcoming events</div>
          <% } %>
        </div>
      </div>
    </div>
  </main>
</div>

<script>
async function approveAlumni(id, btn) {
  if (!confirm('Approve this alumni?')) return;
  btn.disabled = true; btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
  const res = await fetch(`/admin/alumni/${id}/approve`, {method:'POST'});
  const data = await res.json();
  if (data.success) { btn.outerHTML = '<span class="text-xs bg-emerald-100 text-emerald-700 px-2 py-1 rounded-lg font-semibold">Approved</span>'; }
  else { alert(data.message); btn.disabled = false; }
}
async function approveMembership(id, btn) {
  if (!confirm('Approve this membership?')) return;
  btn.disabled = true;
  const res = await fetch(`/admin/memberships/${id}/approve`, {method:'POST'});
  const data = await res.json();
  if (data.success) { document.getElementById(`mem-row-${id}`)?.remove(); }
  else alert(data.message);
}
async function rejectMembership(id) {
  const reason = prompt('Reason for rejection:');
  if (!reason) return;
  const res = await fetch(`/admin/memberships/${id}/reject`, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({reason})});
  const data = await res.json();
  if (data.success) document.getElementById(`mem-row-${id}`)?.remove();
  else alert(data.message);
}
</script>
</body>
</html>
