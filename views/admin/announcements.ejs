<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}</style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen md:min-h-screen">
  <% locals.currentPath = '/admin/announcements'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto pt-14 md:pt-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4 sticky top-0 z-10 flex items-center justify-between">
      <div><h1 class="text-xl font-bold" style="color:#1e3a5f">Announcements</h1><p class="text-gray-500 text-sm">Post updates for alumni</p></div>
      <button onclick="document.getElementById('announce-modal').classList.remove('hidden')" class="text-white font-semibold text-sm px-4 py-2 rounded-xl transition flex items-center gap-2" style="background:#1e3a5f"><i class="fa-solid fa-plus"></i> New Announcement</button>
    </div>

    <div class="p-4 sm:p-6">
      <% if(locals.success_msg&&success_msg.length>0){%><div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-check"></i><%=success_msg%></div><%}%>

      <div class="space-y-4">
        <% if(announcements&&announcements.length>0){announcements.forEach(a=>{%>
        <div class="bg-white rounded-2xl border border-gray-100 p-5 flex items-start gap-4 hover:shadow-md transition" id="ann-<%=a._id%>">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0
            <%=a.type==='urgent'?'bg-red-100':a.type==='event'?'bg-blue-100':'bg-navy-100'%>" style="<%=a.type==='urgent'?'background:#fee2e2':a.type==='event'?'background:#dbeafe':'background:#dce8f3'%>">
            <i class="fa-solid <%=a.type==='urgent'?'fa-triangle-exclamation text-red-600':a.type==='event'?'fa-calendar text-blue-600':'fa-bullhorn text-navy-600'%>"></i>
          </div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-3 mb-1">
              <div>
                <h4 class="font-bold text-gray-800 text-base"><%=a.title%></h4>
                <div class="flex items-center gap-2 mt-0.5">
                  <span class="text-xs px-2 py-0.5 rounded-full font-semibold capitalize
                    <%=a.type==='urgent'?'bg-red-100 text-red-700':a.type==='event'?'bg-blue-100 text-blue-700':'bg-gray-100 text-gray-600'%>"><%=a.type%></span>
                  <span class="text-gray-400 text-xs"><i class="fa-solid fa-user mr-1"></i><%=a.createdBy?a.createdBy.name:'Admin'%></span>
                  <span class="text-gray-400 text-xs"><i class="fa-regular fa-clock mr-1"></i><%=new Date(a.createdAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'})%></span>
                </div>
              </div>
              <button onclick="deleteAnn('<%=a._id%>')" class="flex-shrink-0 text-xs bg-red-50 text-red-500 border border-red-100 px-2.5 py-1.5 rounded-lg hover:bg-red-100 transition font-semibold">
                <i class="fa-solid fa-trash mr-1"></i>Delete
              </button>
            </div>
            <p class="text-gray-600 text-sm leading-relaxed mt-2"><%=a.content%></p>
          </div>
        </div>
        <%})}else{%>
        <div class="text-center py-16 bg-white rounded-2xl border border-gray-100"><i class="fa-solid fa-bullhorn text-4xl text-gray-200 mb-3 block"></i><p class="text-gray-400 font-semibold">No announcements yet</p></div>
        <%}%>
      </div>
    </div>
  </main>
</div>

<!-- Create Announcement Modal -->
<div id="announce-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-md">
    <div class="p-5 border-b border-gray-100 flex items-center justify-between" style="background:linear-gradient(135deg,#0f1e32,#2d6a9f)">
      <h3 class="text-white font-bold text-xl">New Announcement</h3>
      <button onclick="document.getElementById('announce-modal').classList.add('hidden')" class="text-white/60 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
    </div>
    <form action="/admin/announcements" method="POST" class="p-6 space-y-4">
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Title *</label><input type="text" name="title" required placeholder="Announcement title" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Type</label><select name="type" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400"><option value="general">General</option><option value="urgent">Urgent</option><option value="event">Event</option><option value="membership">Membership</option></select></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Content *</label><textarea name="content" required rows="4" placeholder="Write your announcement..." class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea></div>
      <label class="flex items-center gap-2 text-sm font-semibold text-gray-700 cursor-pointer"><input type="checkbox" name="isPublished" checked class="w-4 h-4 rounded"/>Publish immediately</label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 text-white font-bold py-3 rounded-xl" style="background:#1e3a5f"><i class="fa-solid fa-paper-plane mr-2"></i>Publish</button>
        <button type="button" onclick="document.getElementById('announce-modal').classList.add('hidden')" class="flex-1 bg-gray-100 text-gray-700 font-semibold py-3 rounded-xl">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
async function deleteAnn(id){if(!confirm('Delete this announcement?'))return;const f=document.createElement('form');f.method='POST';f.action=`/admin/announcements/${id}?_method=DELETE`;document.body.appendChild(f);f.submit();}
</script>
</body>
</html>
