<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}</style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen">
  <% locals.currentPath = '/admin/events'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto">
    <div class="bg-white border-b border-gray-200 px-6 py-4 sticky top-0 z-10 flex items-center justify-between">
      <div><h1 class="text-xl font-bold" style="color:#1e3a5f">Manage Events</h1><p class="text-gray-500 text-sm"><%= events.length %> events total</p></div>
      <button onclick="document.getElementById('create-modal').classList.remove('hidden')" class="text-white font-semibold text-sm px-4 py-2 rounded-xl transition flex items-center gap-2" style="background:#1e3a5f"><i class="fa-solid fa-plus"></i> Create Event</button>
    </div>

    <div class="p-6">
      <% if(locals.success_msg&&success_msg.length>0){%><div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-check"></i><%=success_msg%></div><%}%>
      <% if(locals.error_msg&&error_msg.length>0){%><div class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-exclamation"></i><%=error_msg%></div><%}%>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% if(events&&events.length>0){events.forEach(e=>{%>
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg transition">
          <div class="p-5">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-xs bg-navy-100 text-navy-700 px-2.5 py-1 rounded-full font-semibold capitalize"><%=e.type%></span>
              <%if(e.isFeatured){%><span class="text-xs bg-gold-100 text-amber-700 px-2.5 py-1 rounded-full font-semibold"><i class="fa-solid fa-star text-xs mr-1"></i>Featured</span><%}%>
              <%if(e.isFree){%><span class="text-xs bg-emerald-100 text-emerald-700 px-2.5 py-1 rounded-full font-semibold">Free</span><%}%>
            </div>
            <h3 class="font-bold text-navy-800 text-base mb-2"><%=e.title%></h3>
            <p class="text-gray-500 text-sm line-clamp-2 mb-3"><%=e.description%></p>
            <div class="space-y-1.5 text-xs text-gray-500">
              <div class="flex items-center gap-2"><i class="fa-solid fa-calendar text-navy-400 w-4"></i><%=new Date(e.date).toLocaleDateString('en-IN',{weekday:'short',year:'numeric',month:'short',day:'numeric'})%></div>
              <div class="flex items-center gap-2"><i class="fa-solid fa-location-dot text-navy-400 w-4"></i><%=e.venue%></div>
              <div class="flex items-center gap-2"><i class="fa-solid fa-users text-navy-400 w-4"></i><%=e.registrationCount||0%> registered</div>
            </div>
          </div>
          <div class="px-5 pb-5 flex gap-2">
            <a href="/events/<%=e._id%>" target="_blank" class="flex-1 text-center text-xs font-semibold text-navy-600 py-2 rounded-lg bg-navy-50 hover:bg-navy-100 transition">
              <i class="fa-solid fa-eye mr-1"></i>View
            </a>
            <button onclick="deleteEvent('<%=e._id%>')" class="flex-1 text-center text-xs font-semibold text-red-600 py-2 rounded-lg bg-red-50 hover:bg-red-100 transition border border-red-100">
              <i class="fa-solid fa-trash mr-1"></i>Delete
            </button>
          </div>
        </div>
        <%})}else{%>
        <div class="col-span-3 text-center py-16 bg-white rounded-2xl border border-gray-100"><i class="fa-solid fa-calendar text-4xl text-gray-200 mb-3 block"></i><p class="text-gray-400 font-semibold">No events yet</p><button onclick="document.getElementById('create-modal').classList.remove('hidden')" class="mt-4 text-sm font-semibold text-white px-5 py-2.5 rounded-xl" style="background:#1e3a5f">Create First Event</button></div>
        <%}%>
      </div>
    </div>
  </main>
</div>

<!-- Create Event Modal -->
<div id="create-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg max-h-screen overflow-y-auto">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between" style="background:linear-gradient(135deg,#0f1e32,#2d6a9f)">
      <h3 class="text-white font-bold text-xl">Create New Event</h3>
      <button onclick="document.getElementById('create-modal').classList.add('hidden')" class="text-white/60 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
    </div>
    <form action="/admin/events" method="POST" class="p-6 space-y-4">
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Event Title *</label><input type="text" name="title" required placeholder="Annual Alumni Meet 2024" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Description *</label><textarea name="description" required rows="3" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Date *</label><input type="datetime-local" name="date" required class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
        <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">End Date</label><input type="datetime-local" name="endDate" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      </div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Venue *</label><input type="text" name="venue" required placeholder="SVPM Campus / Online" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Type</label><select name="type" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400"><option value="seminar">Seminar</option><option value="reunion">Reunion</option><option value="workshop">Workshop</option><option value="cultural">Cultural</option><option value="sports">Sports</option><option value="other">Other</option></select></div>
        <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Max Attendees</label><input type="number" name="maxAttendees" placeholder="0 = unlimited" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      </div>
      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 text-sm font-semibold text-gray-700 cursor-pointer"><input type="checkbox" name="isFree" checked class="w-4 h-4 rounded" />Free Event</label>
        <label class="flex items-center gap-2 text-sm font-semibold text-gray-700 cursor-pointer"><input type="checkbox" name="isFeatured" class="w-4 h-4 rounded" />Featured</label>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 text-white font-bold py-3 rounded-xl transition" style="background:#1e3a5f"><i class="fa-solid fa-plus mr-2"></i>Create Event</button>
        <button type="button" onclick="document.getElementById('create-modal').classList.add('hidden')" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-xl transition">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
async function deleteEvent(id){if(!confirm('Delete this event?'))return;const f=document.createElement('form');f.method='POST';f.action=`/admin/events/${id}?_method=DELETE`;document.body.appendChild(f);f.submit();}
</script>
</body>
</html>
