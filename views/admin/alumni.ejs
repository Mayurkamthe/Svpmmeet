<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}.badge-life{background:linear-gradient(135deg,#f5c842,#c8a31a);color:#1a1a1a;}</style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen md:min-h-screen">
  <% locals.currentPath = '/admin/alumni'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto pt-14 md:pt-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4 flex items-center justify-between sticky top-0 z-10">
      <div><h1 class="text-xl font-bold text-navy-800" style="color:#1e3a5f">Manage Alumni</h1><p class="text-gray-500 text-sm"><%= total %> alumni total</p></div>
      <a href="/admin/export/alumni" class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold text-sm px-4 py-2 rounded-xl transition flex items-center gap-2"><i class="fa-solid fa-file-excel"></i> Export</a>
    </div>
    <div class="p-4 sm:p-6">
      <form method="GET" action="/admin/alumni" class="bg-white rounded-2xl border border-gray-100 p-5 mb-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="relative"><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"><i class="fa-solid fa-search text-xs"></i></span><input type="text" name="search" value="<%= query.search||'' %>" placeholder="Name, email, ID..." class="w-full pl-9 pr-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
          <select name="branch" class="px-4 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400"><option value="">All Branches</option><% branches.forEach(b=>{%><option value="<%=b%>" <%=query.branch===b?'selected':''%>><%=b%></option><%})%></select>
          <select name="year" class="px-4 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400"><option value="">All Years</option><% years.forEach(y=>{%><option value="<%=y%>" <%=query.year==y?'selected':''%>><%=y%></option><%})%></select>
          <select name="status" class="px-4 py-2.5 border border-gray-200 rounded-xl text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-400"><option value="">All Status</option><option value="verified" <%=query.status==='verified'?'selected':''%>>Verified</option><option value="pending" <%=query.status==='pending'?'selected':''%>>Pending</option></select>
          <div class="flex gap-2"><button type="submit" class="flex-1 text-white font-semibold py-2.5 rounded-xl text-sm transition" style="background:#1e3a5f">Search</button><a href="/admin/alumni" class="px-3 py-2.5 border border-gray-200 rounded-xl text-gray-400 hover:bg-gray-50 text-sm"><i class="fa-solid fa-xmark"></i></a></div>
        </div>
      </form>
      <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead><tr class="bg-gray-50 border-b border-gray-100"><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Alumni</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">ID</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Branch/Year</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Membership</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Status</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Joined</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Actions</th></tr></thead>
            <tbody class="divide-y divide-gray-50">
              <% if(alumni&&alumni.length>0){alumni.forEach(a=>{%>
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-4"><div class="flex items-center gap-3"><div class="w-9 h-9 rounded-xl overflow-hidden bg-blue-50 flex items-center justify-center flex-shrink-0 font-bold text-blue-700"><% if(a.avatar){%><img src="<%=a.avatar%>" class="w-full h-full object-cover"><%}else{%><%=a.name.charAt(0)%><%}%></div><div><p class="font-semibold text-gray-800"><%=a.name%></p><p class="text-gray-400 text-xs"><%=a.email%></p></div></div></td>
                <td class="px-5 py-4 font-mono text-xs text-gray-500"><%=a.alumniId%></td>
                <td class="px-5 py-4"><p class="text-gray-700 text-xs font-semibold"><%=a.profile&&a.profile.branch?a.profile.branch.split(' ')[0]:'N/A'%></p><p class="text-gray-400 text-xs"><%=a.profile&&a.profile.passOutYear?a.profile.passOutYear:'N/A'%></p></td>
                <td class="px-5 py-4"><span class="text-xs font-bold px-2.5 py-1 rounded-full <%=a.membershipStatus==='approved'?'badge-life':a.membershipStatus==='pending'?'bg-amber-100 text-amber-700':'bg-gray-100 text-gray-500'%>"><%=a.membershipStatus==='approved'?'Life Member':a.membershipStatus==='pending'?'Pending':'None'%></span></td>
                <td class="px-5 py-4"><span class="text-xs font-bold px-2.5 py-1 rounded-full <%=a.isVerified?'bg-emerald-100 text-emerald-700':'bg-amber-100 text-amber-700'%>"><%=a.isVerified?'Verified':'Pending'%></span></td>
                <td class="px-5 py-4 text-gray-400 text-xs"><%=new Date(a.createdAt).toLocaleDateString('en-IN',{month:'short',day:'numeric',year:'numeric'})%></td>
                <td class="px-5 py-4"><div class="flex items-center gap-1.5"><%if(!a.isVerified){%><button onclick="approveAlumni('<%=a._id%>',this)" class="text-xs bg-emerald-50 hover:bg-emerald-100 text-emerald-700 border border-emerald-200 px-2 py-1.5 rounded-lg" title="Approve"><i class="fa-solid fa-check"></i></button><button onclick="rejectAlumni('<%=a._id%>',this)" class="text-xs bg-orange-50 hover:bg-orange-100 text-orange-700 border border-orange-200 px-2 py-1.5 rounded-lg" title="Reject"><i class="fa-solid fa-xmark"></i></button><%}%><a href="mailto:<%=a.email%>" class="text-xs bg-blue-50 text-blue-600 border border-blue-200 px-2 py-1.5 rounded-lg" title="Email"><i class="fa-solid fa-envelope"></i></a><button onclick="deleteAlumni('<%=a._id%>')" class="text-xs bg-red-50 text-red-600 border border-red-200 px-2 py-1.5 rounded-lg" title="Delete"><i class="fa-solid fa-trash"></i></button></div></td>
              </tr>
              <%})}else{%><tr><td colspan="7" class="px-5 py-12 text-center text-gray-400"><i class="fa-solid fa-users text-3xl mb-2 block text-gray-200"></i>No alumni found</td></tr><%}%>
            </tbody>
          </table>
        </div>
        <% if(totalPages>1){%><div class="px-5 py-4 border-t border-gray-50 flex items-center justify-between"><span class="text-sm text-gray-500">Page <%=page%> of <%=totalPages%></span><div class="flex gap-2"><%if(page>1){%><a href="?page=<%=page-1%>&search=<%=query.search||''%>&branch=<%=query.branch||''%>&status=<%=query.status||''%>" class="px-3 py-1.5 border border-gray-200 rounded-lg text-xs font-semibold text-gray-600 hover:bg-gray-50">Prev</a><%}%><%for(let i=Math.max(1,page-2);i<=Math.min(totalPages,page+2);i++){%><a href="?page=<%=i%>&search=<%=query.search||''%>&branch=<%=query.branch||''%>&status=<%=query.status||''%>" class="px-3 py-1.5 rounded-lg text-xs font-semibold <%=i===page?'text-white':'border border-gray-200 text-gray-600 hover:bg-gray-50'%>" <%=i===page?'style="background:#1e3a5f"':''%>><%=i%></a><%}%><%if(page<totalPages){%><a href="?page=<%=page+1%>&search=<%=query.search||''%>&branch=<%=query.branch||''%>&status=<%=query.status||''%>" class="px-3 py-1.5 border border-gray-200 rounded-lg text-xs font-semibold text-gray-600 hover:bg-gray-50">Next</a><%}%></div></div><%}%>
      </div>
    </div>
  </main>
</div>
<script>
async function approveAlumni(id,btn){if(!confirm('Approve this alumni?'))return;btn.disabled=true;try{const r=await fetch(`/admin/alumni/${id}/approve`,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'}});const d=await r.json();if(d.success)location.reload();else{alert(d.message);btn.disabled=false;}}catch(e){alert('Error: '+e.message);btn.disabled=false;}}
async function rejectAlumni(id,btn){if(!confirm('Reject this alumni?'))return;btn.disabled=true;try{const r=await fetch(`/admin/alumni/${id}/reject`,{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json'}});const d=await r.json();if(d.success)location.reload();else{alert(d.message);btn.disabled=false;}}catch(e){alert('Error: '+e.message);btn.disabled=false;}}
async function deleteAlumni(id){if(!confirm('Permanently delete this alumni?'))return;const f=document.createElement('form');f.method='POST';f.action=`/admin/alumni/${id}`;const inp=document.createElement('input');inp.type='hidden';inp.name='_method';inp.value='DELETE';f.appendChild(inp);document.body.appendChild(f);f.submit();}
</script>
</body>
</html>
