<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script>tailwind.config={theme:{extend:{colors:{navy:{50:'#f0f4f9',100:'#dce8f3',200:'#b9d0e7',300:'#8db0d4',400:'#5f8dbe',500:'#3a70a8',600:'#2d6a9f',700:'#1e3a5f',800:'#172d4a',900:'#0f1e32'},gold:{100:'#fef9e7',400:'#f5c842',500:'#e8b820',600:'#c8a31a'}}}}}</script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}</style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen md:min-h-screen">
  <% locals.currentPath = '/admin/membership-plans'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4 sticky top-0 z-10 flex items-center justify-between">
      <div><h1 class="text-xl font-bold" style="color:#1e3a5f">Membership Plans</h1><p class="text-gray-500 text-sm"><%= plans.length %> plans total</p></div>
      <button onclick="document.getElementById('create-modal').classList.remove('hidden')" class="text-white font-semibold text-sm px-4 py-2 rounded-xl transition flex items-center gap-2" style="background:#1e3a5f"><i class="fa-solid fa-plus"></i> Create Plan</button>
    </div>

    <div class="p-4 sm:p-6">
      <% if(locals.success_msg&&success_msg.length>0){%><div class="mb-4 flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-check"></i><%=success_msg%></div><%}%>
      <% if(locals.error_msg&&error_msg.length>0){%><div class="mb-4 flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-xl text-sm"><i class="fa-solid fa-circle-exclamation"></i><%=error_msg%></div><%}%>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% if(plans&&plans.length>0){plans.forEach(p=>{%>
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-lg transition flex flex-col">
          <div class="p-5 flex-1">
            <div class="flex items-center gap-2 mb-3">
              <%if(p.isFeatured){%><span class="text-xs bg-gold-100 text-amber-700 px-2.5 py-1 rounded-full font-semibold"><i class="fa-solid fa-star text-xs mr-1"></i>Featured</span><%}%>
              <%if(p.isActive){%><span class="text-xs bg-emerald-100 text-emerald-700 px-2.5 py-1 rounded-full font-semibold">Active</span><%}else{%><span class="text-xs bg-gray-100 text-gray-700 px-2.5 py-1 rounded-full font-semibold">Inactive</span><%}%>
            </div>
            <h3 class="font-bold text-navy-800 text-xl mb-1"><%=p.title%></h3>
            <div class="text-gold-500 font-bold text-2xl mb-3">₹<%=p.amount.toLocaleString('en-IN')%></div>
            <p class="text-gray-500 text-sm line-clamp-3 mb-4"><%=p.description%></p>
            <ul class="space-y-1.5 text-xs text-gray-600 mb-4">
              <% p.benefits.forEach(b => { %>
                <li class="flex items-start gap-2"><i class="fa-solid fa-check text-emerald-500 mt-0.5"></i><%=b%></li>
              <% }) %>
            </ul>
          </div>
          <div class="px-5 pb-5 flex gap-2">
            <button onclick="deletePlan('<%=p._id%>')" class="w-full text-center text-xs font-semibold text-red-600 py-2.5 rounded-xl bg-red-50 hover:bg-red-100 transition border border-red-100">
              <i class="fa-solid fa-trash mr-1"></i>Delete
            </button>
          </div>
        </div>
        <%})}else{%>
        <div class="col-span-3 text-center py-16 bg-white rounded-2xl border border-gray-100"><i class="fa-solid fa-id-card text-4xl text-gray-200 mb-3 block"></i><p class="text-gray-400 font-semibold">No membership plans yet</p><button onclick="document.getElementById('create-modal').classList.remove('hidden')" class="mt-4 text-sm font-semibold text-white px-5 py-2.5 rounded-xl" style="background:#1e3a5f">Create First Plan</button></div>
        <%}%>
      </div>
    </div>
  </main>
</div>

<!-- Create Plan Modal -->
<div id="create-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50 p-4">
  <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg max-h-screen overflow-y-auto">
    <div class="p-6 border-b border-gray-100 flex items-center justify-between" style="background:linear-gradient(135deg,#0f1e32,#2d6a9f)">
      <h3 class="text-white font-bold text-xl">Create Membership Plan</h3>
      <button onclick="document.getElementById('create-modal').classList.add('hidden')" class="text-white/60 hover:text-white"><i class="fa-solid fa-xmark text-xl"></i></button>
    </div>
    <form action="/admin/membership-plans" method="POST" class="p-6 space-y-4">
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Plan Title *</label><input type="text" name="title" required placeholder="e.g., Lifetime Patron" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Description *</label><textarea name="description" required rows="2" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Amount (₹) *</label><input type="number" name="amount" required min="0" placeholder="1000" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400"/></div>
      <div><label class="block text-gray-700 font-semibold text-sm mb-1.5">Benefits (Comma separated)</label><textarea name="benefits" rows="2" placeholder="Priority registration, Free access to library, Custom ID card" class="w-full px-4 py-2.5 border border-gray-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea></div>
      <div class="flex items-center gap-6">
        <label class="flex items-center gap-2 text-sm font-semibold text-gray-700 cursor-pointer"><input type="checkbox" name="isFeatured" class="w-4 h-4 rounded" />Featured Plan</label>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="flex-1 text-white font-bold py-3 rounded-xl transition" style="background:#1e3a5f"><i class="fa-solid fa-plus mr-2"></i>Create Plan</button>
        <button type="button" onclick="document.getElementById('create-modal').classList.add('hidden')" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 rounded-xl transition">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
async function deletePlan(id){if(!confirm('Delete this plan?'))return;const f=document.createElement('form');f.method='POST';f.action=`/admin/membership-plans/${id}?_method=DELETE`;document.body.appendChild(f);f.submit();}
</script>
</body>
</html>
