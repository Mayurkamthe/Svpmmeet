<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/>
  <title><%= title %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
  <style>body{font-family:'Source Sans 3',system-ui,sans-serif;}.gradient-header{background:linear-gradient(135deg,#0f1e32 0%,#1e3a5f 50%,#2d6a9f 100%);}.sidebar-link.active{background:rgba(255,255,255,0.15);border-left:3px solid #f5c842;}.sidebar-link:hover{background:rgba(255,255,255,0.1);}</style>
</head>
<body class="bg-gray-100">
<div class="flex min-h-screen md:min-h-screen">
  <% locals.currentPath = '/admin/payments'; %>
  <%- include('../partials/admin-sidebar') %>
  <main class="flex-1 overflow-y-auto pt-14 md:pt-0 min-w-0">
    <div class="bg-white border-b border-gray-200 px-4 sm:px-6 py-4 sticky top-0 z-10">
      <h1 class="text-xl font-bold" style="color:#1e3a5f">Payment Management</h1>
      <p class="text-gray-500 text-sm">Total Revenue: <strong class="text-emerald-600">₹<%= revenue.toLocaleString('en-IN') %></strong></p>
    </div>
    <div class="p-4 sm:p-6">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
        <div class="bg-white rounded-2xl border border-gray-100 p-5"><div class="text-gray-500 text-xs font-semibold uppercase mb-1">Total Revenue</div><div class="text-2xl font-bold text-emerald-600">₹<%= revenue.toLocaleString('en-IN') %></div></div>
        <div class="bg-white rounded-2xl border border-gray-100 p-5"><div class="text-gray-500 text-xs font-semibold uppercase mb-1">Total Payments</div><div class="text-2xl font-bold" style="color:#1e3a5f"><%= total %></div></div>
        <div class="bg-white rounded-2xl border border-gray-100 p-5"><div class="text-gray-500 text-xs font-semibold uppercase mb-1">Filter</div>
          <div class="flex gap-2">
            <% ['', 'paid','failed','created'].forEach((s,i)=>{ %>
            <a href="/admin/payments?status=<%= s %>" class="text-xs px-3 py-1.5 rounded-lg font-semibold transition
              <%= (query.status||'')=== s ? 'text-white' : 'bg-gray-50 border border-gray-200 text-gray-600 hover:bg-gray-100' %>"
              <%=(query.status||'')=== s?'style="background:#1e3a5f"':''%>>
              <%= s===''?'All':s.charAt(0).toUpperCase()+s.slice(1) %>
            </a>
            <% }) %>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead><tr class="bg-gray-50 border-b border-gray-100"><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Receipt</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Alumni</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Purpose</th><th class="text-right px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Amount</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Status</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Date</th><th class="text-left px-5 py-3.5 text-gray-500 font-bold text-xs uppercase">Receipt</th></tr></thead>
            <tbody class="divide-y divide-gray-50">
              <% if(payments&&payments.length>0){payments.forEach(p=>{%>
              <tr class="hover:bg-gray-50">
                <td class="px-5 py-4 font-mono text-xs text-gray-500"><%=p.receiptNumber%></td>
                <td class="px-5 py-4"><p class="font-semibold text-gray-800 text-sm"><%=p.user?p.user.name:'N/A'%></p><p class="text-gray-400 text-xs"><%=p.user?p.user.alumniId:''%></p></td>
                <td class="px-5 py-4 text-gray-700 capitalize text-xs font-semibold"><%=p.purpose?p.purpose.replace(/_/g,' '):'N/A'%></td>
                <td class="px-5 py-4 text-right font-bold text-lg <%=p.status==='paid'?'text-emerald-600':'text-gray-400'%>">₹<%=p.amount.toLocaleString('en-IN')%></td>
                <td class="px-5 py-4"><span class="text-xs font-bold px-2.5 py-1 rounded-full <%=p.status==='paid'?'bg-emerald-100 text-emerald-700':p.status==='failed'?'bg-red-100 text-red-700':'bg-amber-100 text-amber-700'%>"><%=p.status.toUpperCase()%></span></td>
                <td class="px-5 py-4 text-gray-400 text-xs"><%=p.paidAt?new Date(p.paidAt).toLocaleDateString('en-IN',{year:'numeric',month:'short',day:'numeric'}):'-'%></td>
                <td class="px-5 py-4"><%if(p.status==='paid'){%><a href="/payments/receipt/<%=p._id%>" class="text-xs bg-blue-50 text-blue-600 border border-blue-200 font-semibold px-3 py-1.5 rounded-lg hover:bg-blue-100 transition"><i class="fa-solid fa-download mr-1"></i>PDF</a><%}%></td>
              </tr>
              <%})}else{%><tr><td colspan="7" class="px-5 py-12 text-center text-gray-400"><i class="fa-solid fa-receipt text-3xl mb-2 block text-gray-200"></i>No payments found</td></tr><%}%>
            </tbody>
          </table>
        </div>
        <%if(totalPages>1){%><div class="px-5 py-4 border-t border-gray-50 flex items-center justify-between"><span class="text-sm text-gray-500">Page <%=page%> of <%=totalPages%></span><div class="flex gap-2"><%if(page>1){%><a href="?page=<%=page-1%>&status=<%=query.status||''%>" class="px-3 py-1.5 border border-gray-200 rounded-lg text-xs font-semibold text-gray-600 hover:bg-gray-50">Prev</a><%}%><%if(page<totalPages){%><a href="?page=<%=page+1%>&status=<%=query.status||''%>" class="px-3 py-1.5 border border-gray-200 rounded-lg text-xs font-semibold text-gray-600 hover:bg-gray-50">Next</a><%}%></div></div><%}%>
      </div>
    </div>
  </main>
</div>
</body>
</html>
